@inject UserService UserService
@inject IJSRuntime JSRuntime
@using ScreenTracker1.Models
@using ScreenTracker1.Services
@using ScreenTracker1.DTOS
@using Microsoft.JSInterop
@using System.IdentityModel.Tokens.Jwt
@inject NavigationManager NavigationManager
@inject DesktopAutoCaptureService desktopAutoCaptureService
@inject AfkTrackerService afkTrackerService
@inject AppUsageTracker appUsageTrackerService
@inject NativeThemeService NativeThemeService
@inject SystemThemeService SystemThemeService
@inject UserSelectionStateService UserStateService
@inject SessionKeepAliveService SessionKeepAliveService

<div class="stitch-header">
    <div class="header-content">
       

        @* <NavLink href="/dashboard" class="nav-link">
            <i class="bi bi-calendar3"></i> Calendar
        </NavLink> *@

        <NavLink href="/users" class="nav-link">
            <i class="bi bi-house-door"></i> Dashboard
        </NavLink>
        
        @if (!string.IsNullOrEmpty(UserRole) &&
        (UserRole.Equals("admin", StringComparison.OrdinalIgnoreCase) ||
        UserRole.Equals("superadmin", StringComparison.OrdinalIgnoreCase)))
        {
            <NavLink href="/active-users" class="nav-link">
                <i class="bi bi-person-circle"></i> Active Users
            </NavLink>
        }

        <NavLink href="@($"rptTime/{UserId}?usageType=all")" class="nav-link">
            <i class="bi bi-bar-chart-line"></i> Reports
        </NavLink>

        @if (!string.IsNullOrEmpty(UserRole))
        {
            @if (UserRole.Equals("superadmin", StringComparison.OrdinalIgnoreCase))
            {
                <NavLink href="/admin-list" class="nav-link">
                    <i class="bi bi-people"></i> Admin List
                </NavLink>
            }
            else if (UserRole.Equals("admin", StringComparison.OrdinalIgnoreCase))
            {
                <NavLink href="@($"/admin-users/{UserId}")" class="nav-link">
                    <i class="bi bi-people"></i> User List
                </NavLink>
            }
        }

        @if (!string.IsNullOrEmpty(UserRole) &&
             (UserRole.Equals("admin", StringComparison.OrdinalIgnoreCase) ||
              UserRole.Equals("superadmin", StringComparison.OrdinalIgnoreCase)))
        {
            <NavLink href="/settings" class="nav-link">
                <i class="bi bi-gear"></i> Settings
            </NavLink>
        }
@* 
        @if (!string.IsNullOrEmpty(UserRole))
        {
              @if (UserRole.Equals("superadmin", StringComparison.OrdinalIgnoreCase))
              {
                  <NavLink href="/register" class="nav-link">
                      <i class="bi bi-person-plus"></i> Add Admin
                  </NavLink>
              }
              else 
            if (UserRole.Equals("admin", StringComparison.OrdinalIgnoreCase))
            {
                <NavLink href="/register" class="nav-link">
                    <i class="bi bi-person-plus"></i> Add User
                </NavLink>
            }
        }
 *@
    </div>


    <div class="tooltip-container" style="z-index:4;" @onclick:stopPropagation>
        <h3 class="stitch-heading">Welcome @UserName</h3>
        <button class="user-menu-button" @onclick="ToggleMenu">
            <i class="fas fa-user-circle"></i>
        </button>
   @*         <span class="tooltip-text tooltip-text-user">User options</span> *@
        @if (showMenu)
        {
            <ul class="user-menu-dropdown" style="right: 0;">
                <li><button class="menu-item-btn" @onclick="ToggleThemePopup">Theme</button></li>
                <li><NavLink href="/profile" class="menu-item-btn" @onclick="CloseMenu">Profile</NavLink></li>
         
       @*           @if (UserRole.ToLower() == "admin" || UserRole.ToLower()=="superadmin")
                 {
                     <li><button class="menu-item-btn" @onclick="NavigateToSettings">Settings</button></li>
                     <li><button class="menu-item-btn" @onclick="NavigateToRegister">Add User</button></li>
                 }
 *@

                <li><button class="menu-item-btn" @onclick="OnLogoutClicked">Logout</button></li>

            </ul>
        }

    </div>

    @if (showMenu)
    {
        <div class="overlay" @onclick="CloseMenu"></div>
    }

    @if (showThemePopup)
    {
        <div class="popup-container" @onclick="CloseThemePopup">
            <div class="theme-container" @onclick:stopPropagation>
                <div class="theme-section">
                    <label class="theme-label">Theme Mode</label>
                    <div class="theme-controls-row">
                        <div class="theme-dropdown-wrapper">
                            <select class="theme-dropdown" @onchange="OnThemeChanged">
                                <option value="system" selected="@(selectedTheme == "system")">🖥️ System Default</option>
                                <option value="dark" selected="@(selectedTheme == "dark")">🌙 Dark Mode</option>
                                <option value="light" selected="@(selectedTheme == "light")">☀️ Light Mode</option>
                            </select>
                        </div>
                        <button class="theme-toggle-btn" @onclick="ToggleTheme" title="@(isDarkTheme ? "Switch to Light" : "Switch to Dark")">
                            <i class="fas @themeIcon"></i>
                        </button>
                    </div>
                    <div class="theme-indicator">
                        <i class="fas @(isDarkTheme ? "fa-moon" : "fa-sun")"></i>
                        <span>@(isDarkTheme ? "Dark Theme Active" : "Light Theme Active")</span>
                    </div>
                </div>
                <button class="theme-back-btn" @onclick="CloseThemePopup">
                    <i class="fas fa-times"></i> Close
                </button>
            </div>
        </div>
    }

    @if (showLogoutConfirm)
    {
        <div class="popup-container" @onclick="CancelLogout">
            <div class="theme-container logout-confirm-container" @onclick:stopPropagation>
                <div class="theme-section">
                    <label class="theme-label">Confirm Logout</label>
                    <p class="logout-confirm-text">Are you sure you want to logout?</p>
                    <div class="logout-confirm-actions">
                        <button class="logout-btn-yes" @onclick="ConfirmLogout">Yes, Logout</button>
                        <button class="logout-btn-cancel" @onclick="CancelLogout">Cancel</button>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@code {
    private bool showMenu = false;
    private bool showThemePopup = false;
    private bool showLogoutConfirm = false;
    private string selectedTheme = "system";
    private string themeIcon = "fa-sun";
    private string? UserName;
    private bool isDarkTheme;
    private IJSObjectReference? themeModule;
    private bool isOn = false;
    private IJSObjectReference? localStorageModule;
    private string? token;
    private int UserId { get; set; }
    private string? UserRole;

    [Parameter]
    public EventCallback OnLogoutTriggered { get; set; }

    // private async Task OnLogoutClicked()
    // {
    //     // Close the menu first
    //     CloseMenu();

    //     // Invoke the EventCallback, which will execute the method in the parent component
    //     await OnLogoutTriggered.InvokeAsync();
    // }

    protected override async Task OnInitializedAsync()
    {
        token = Preferences.Get("authToken", null);

        if (!string.IsNullOrEmpty(token))
        {
            var handler = new JwtSecurityTokenHandler();
            var jwtToken = handler.ReadToken(token) as JwtSecurityToken;

            if (jwtToken != null)
            {
                UserName = jwtToken.Claims
                  .FirstOrDefault(c => c.Type == "http://schemas.xmlsoap.org/ws/2005/05/identity/claims/name")?.Value;

                var userIdClaim = jwtToken.Claims
                  .FirstOrDefault(c => c.Type == "http://schemas.xmlsoap.org/ws/2005/05/identity/claims/nameidentifier")?.Value;
                if (int.TryParse(userIdClaim, out int loggedInUserId))
                {
                    UserId = loggedInUserId;
                }


                UserRole = jwtToken.Claims
                  .FirstOrDefault(c => c.Type == "http://schemas.microsoft.com/ws/2008/06/identity/claims/role")?.Value;
            }

        }
    }

    private void ToggleMenu() => showMenu = !showMenu;

    private void ToggleThemePopup()
    {
        showThemePopup = !showThemePopup;
        CloseMenu();
    }

    private void NavigateToSettings()
    {
        NavigationManager.NavigateTo("/settings");
    }
    private void NavigateToRegister()
    {
        NavigationManager.NavigateTo("/register");
    }
    private void CloseMenu()
    {
        showMenu = false;
        StateHasChanged();
    }

    private void CloseThemePopup() => showThemePopup = false;

    private async Task OnThemeChanged(ChangeEventArgs e)
    {
        if (e.Value != null)
        {
            selectedTheme = e.Value.ToString();
            
            if (themeModule != null)
            {
                await themeModule.InvokeVoidAsync("saveThemePreference", selectedTheme);
                isDarkTheme = await themeModule.InvokeAsync<bool>("getSavedTheme");
                await UpdateThemeIcon();
                await UpdateChartTheme();
                NativeThemeService.SetDarkMode(isDarkTheme);
            }
        }
    }

    private void OnLogoutClicked()
    {
        CloseMenu();
        showLogoutConfirm = true;
    }

    private void CancelLogout()
    {
        showLogoutConfirm = false;
    }

    private async Task ConfirmLogout()
    {
        showLogoutConfirm = false;

        // Prevent in-flight requests from presenting an intentional logout as a
        // conflicting-device/session-expired error.
        UserService.BeginIntentionalLogout();
        SessionKeepAliveService.Stop();

        // 1. Stop tracking services if they were active
        if (isOn)
        {
            isOn = false;
            await localStorageModule.InvokeVoidAsync("setIsOnState", isOn);
            appUsageTrackerService.Stop();
            appUsageTrackerService.ClearUserData();
            desktopAutoCaptureService.StopTimer();
            afkTrackerService.Stop();

            // Superadmins are view-only and never own a tracking session.
            if (!string.Equals(UserRole, "superadmin", StringComparison.OrdinalIgnoreCase))
            {
                await UserService.EndDailyTrackerAsync();
            }
        }

        // Notify the backend while the current token is still available.
        await UserService.LogoutAsync();

        // 2. Clear authentication tokens
        SecureStorage.Remove("auth_token");
        SecureStorage.Remove("authToken");
        Preferences.Remove("authToken");
        Preferences.Remove("auth_token");

        // 3. CLEAR THE USER-SPECIFIC STATE IN THE SERVICE (RESET ON LOGOUT)
        UserStateService.UserId = 0; // Clear the User ID (since it's not nullable, use 0)
        UserStateService.SelectedUsername = null;
        UserStateService.SelectedAdminUsername = null;
        UserStateService.SelectedUsageType = "all"; // Reset to default value
        UserStateService.SelectedDate = DateTime.Today; // Reset to default value
        UserStateService.Admins = new List<User>(); // Clear the list
        UserStateService.Users = new List<User>(); // Clear the list

        // Clear any application-wide selected ID (if App is a static class/property)
        App.SelectedUserId = 0;
        App.SelectedUsername = string.Empty;
        App.SelectedAdminUsername = string.Empty;
        App.selectedUsageType = "all";

        // 4. Update UI and navigate
        StateHasChanged();
        NavigationManager.NavigateTo("/login");
    }

    private async Task ToggleTheme()
    {
        if (themeModule != null)
        {
            await themeModule.InvokeVoidAsync("toggleTheme");
            isDarkTheme = !isDarkTheme;
            selectedTheme = isDarkTheme ? "dark" : "light";
            await UpdateThemeIcon();
            await UpdateChartTheme();
            NativeThemeService.SetDarkMode(isDarkTheme);
            }
    }

    private async Task UpdateThemeIcon()
    {
        themeIcon = isDarkTheme ? "fa-moon" : "fa-sun";
    }

    private async Task UpdateChartTheme()
    {
        await JSRuntime.InvokeVoidAsync("eval", $"if (typeof window.updateChartThemeColor !== 'undefined') {{ window.updateChartThemeColor({isDarkTheme.ToString().ToLower()}); }}");
    }

 


    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            themeModule = await JSRuntime.InvokeAsync<IJSObjectReference>("import", "./js/theme.js");
            localStorageModule = await JSRuntime.InvokeAsync<IJSObjectReference>("import", "./js/localStorage.js");
            
            // Load saved theme preference
            var savedTheme = await themeModule.InvokeAsync<string>("getSavedThemePreference");
            selectedTheme = savedTheme;
            
            // Apply the saved theme
            isDarkTheme = await themeModule.InvokeAsync<bool>("getSavedTheme");
            await UpdateThemeIcon();
            NativeThemeService.SetDarkMode(isDarkTheme);
            
            isOn = false;
            await localStorageModule.InvokeVoidAsync("setIsOnState", isOn);
            StateHasChanged();
        }
    }
}
