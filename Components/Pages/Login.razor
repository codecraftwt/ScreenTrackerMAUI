@page "/"
@page "/login"

@using ScreenTracker1.Models
@using Microsoft.AspNetCore.Components.Forms
@using ScreenTracker1.Services
@using System.IdentityModel.Tokens.Jwt
@using System.Runtime.InteropServices

@inject NavigationManager NavigationManager
@inject IJSRuntime JSRuntime
@inject LoginService LoginService
@inject AppUsageTracker AppUsageTracker
@inject IAutoCaptureService desktopAutoCaptureService
@inject AfkTrackerService afkTrackerService
@inject AppUsageTracker appUsageTrackerService
@inject UserService UserService
@inject UserSelectionStateService UserStateService

@layout ScreenTracker1.Components.Layout.NoNavLayout

<div class="login-container">
    <div class="login-card">
        <div class="login-header">
            <div class="login-icon">
                <i class="fas fa-users"></i>
            </div>
            <h1 class="login-title">Employee Tracking</h1>
            <p class="login-subtitle">Sign in to access your account</p>
        </div>

        <EditForm Model="@loginModel" OnValidSubmit="@HandleLogin">
            <DataAnnotationsValidator />
            <ValidationSummary />

            <div class="form-group">
                <label class="form-label">Username</label>
                <input value="@loginModel.username"
                       @oninput="OnUsernameInput"
                       type="text"
                       class="form-input"
                       placeholder="Enter your username" />
            </div>

            <div class="form-group">
                <label class="form-label">Password</label>
                <div class="password-group">
                    <input value="@loginModel.password"
                           @oninput="OnPasswordInput"
                           type="@passwordInputType"
                           class="form-input"
                           placeholder="Enter your password" />

                    <button type="button" class="toggle-password" @onclick="TogglePasswordVisibility">
                        <i class="@(showPassword ? "fas fa-eye-slash" : "fas fa-eye")"></i>
                    </button>
                </div>
            </div>

            <div class="form-options">
                <div class="checkbox-container">
                    <InputCheckbox @bind-Value="loginModel.rememberMe" />
                    <label class="checkbox-label">Remember me</label>
                </div>

                <a href="/forgot-password" class="forgot-link">Forgot Password?</a>
            </div>

            @if (!CanSignIn)
            {
                <p class="form-hint">Please enter both Username and Password to continue.</p>
            }

            <button type="submit" class="submit-btn" disabled="@(!CanSignIn)">
                Sign In
            </button>
        </EditForm>

        <div class="divider">
            <div class="divider-line"></div>
            <span class="divider-text">OR</span>
            <div class="divider-line"></div>
        </div>

        @* Google login currently disabled *@
        @*
        <button class="google-btn" @onclick="SignInWithGoogle">
            Sign in with Google
        </button>
        *@

        @if (!string.IsNullOrEmpty(message))
        {
            <p class="message">@message</p>
        }

        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <p class="error-message">@errorMessage</p>
        }

        <div class="login-footer">
            <p class="footer-text">
                Don't have an account?
                <a href="#" class="footer-link">Contact your administrator</a>
            </p>
        </div>
    </div>
</div>

@code {
    private LoginModel loginModel = new();

    private string? message;
    private string? errorMessage;

    private int uid;

    private IJSObjectReference? themeModule;

    private bool showPassword = false;

    private string passwordInputType => showPassword ? "text" : "password";

    private bool CanSignIn =>
        !string.IsNullOrWhiteSpace(loginModel.username)
        && !string.IsNullOrWhiteSpace(loginModel.password);

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                themeModule = await JSRuntime.InvokeAsync<IJSObjectReference>("import", "./js/theme.js");

                bool isDarkTheme = await themeModule.InvokeAsync<bool>("getSystemTheme");

                await themeModule.InvokeVoidAsync("setTheme", isDarkTheme);

                await themeModule.DisposeAsync();
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Theme load error: {ex.Message}");
            }
        }
    }

    protected override async Task OnInitializedAsync()
    {
        try
        {
            // A previous intentional logout or session-expired reset may have
            // been interrupted when the app was quit. Never auto-login with
            // credentials left behind by that interrupted cleanup.
            if (Preferences.Get("isLoggingOut", false))
            {
                Preferences.Remove("authToken");
                Preferences.Remove("auth_token");
                SecureStorage.Remove("authToken");
                SecureStorage.Remove("auth_token");
            }

            string? savedUsername;

#if MACCATALYST
            savedUsername = Preferences.Get("saved_username", string.Empty);
#else
            savedUsername = await SecureStorage.GetAsync("saved_username");
#endif

            if (!string.IsNullOrEmpty(savedUsername))
            {
                loginModel.username = savedUsername;
                loginModel.rememberMe = true;
            }

            string? token;

#if MACCATALYST
            token = Preferences.Get("auth_token", string.Empty);

            if (string.IsNullOrEmpty(token))
            {
                token = Preferences.Get("authToken", string.Empty);
            }
#else
            token = await SecureStorage.GetAsync("auth_token");
#endif

            if (!string.IsNullOrEmpty(token))
            {
                var handler = new JwtSecurityTokenHandler();

                try
                {
                    var jwt = handler.ReadJwtToken(token);

                    if (jwt.ValidTo > DateTime.UtcNow)
                    {
                        Preferences.Set("authToken", token);
                        Preferences.Set("auth_token", token);

                        var userIdClaim = jwt.Claims
                            .FirstOrDefault(c =>
                                c.Type == "http://schemas.xmlsoap.org/ws/2005/05/identity/claims/nameidentifier")
                            ?.Value;

                        var userRole = jwt.Claims
                            .FirstOrDefault(c =>
                                c.Type == "http://schemas.microsoft.com/ws/2008/06/identity/claims/role")
                            ?.Value;

                        if (int.TryParse(userIdClaim, out int userId))
                        {
                            uid = userId;
                            UserService.SetUserId(userId);

                            // A locally unexpired JWT may already be invalid on
                            // the server. Validate every role, including
                            // superadmin, before performing automatic login.
                            bool sessionValid = await UserService.TryHeartbeatRecoveryAsync();
                            if (sessionValid && userRole?.ToLower() != "superadmin")
                            {
                                sessionValid = await DetermineTrackingStateAsync(userId, userRole);
                            }

                            if (sessionValid)
                            {
                                UserStateService.UserId = 0;
                                UserStateService.SelectedUsername = null;
                                UserStateService.SelectedAdminUsername = null;
                                UserStateService.Admins = new();
                                UserStateService.Users = new();
                                UserStateService.SelectedUsageType = "all";
                                UserStateService.SelectedDate = DateTime.Today;

                                App.first = true;
                                NavigationManager.NavigateTo("/users");
                                return;
                            }

                            // Server rejected the session — clear stale tokens and show login
                            Preferences.Remove("authToken");
                            Preferences.Remove("auth_token");
#if !MACCATALYST
                            SecureStorage.Remove("auth_token");
                            SecureStorage.Remove("saved_username");
#else
                            Preferences.Remove("saved_username");
#endif
                        }
                    }
                }
                catch (Exception ex)
                {
                    Console.WriteLine($"Token read error: {ex.Message}");

                    Preferences.Remove("authToken");
                    Preferences.Remove("auth_token");

#if !MACCATALYST
                    SecureStorage.Remove("auth_token");
#endif
                }
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Login initialization error: {ex.Message}");
        }
    }

    private void OnUsernameInput(ChangeEventArgs e)
    {
        loginModel.username = e.Value?.ToString() ?? string.Empty;
    }

    private void OnPasswordInput(ChangeEventArgs e)
    {
        loginModel.password = e.Value?.ToString() ?? string.Empty;
    }

    private void TogglePasswordVisibility()
    {
        showPassword = !showPassword;
    }

    private async Task HandleLogin()
    {
        if (!CanSignIn)
        {
            return;
        }

        try
        {
            errorMessage = null;
            message = null;

            /*
             IMPORTANT:
             Do not call UserService.LogoutAsync() before login.
             On macOS this can disturb the backend active-device/session handling
             and may cause: "You have logged in from another device. Please log in again."
            */

            var result = await LoginService.LoginAsync(loginModel);

            if (string.IsNullOrEmpty(result) || result.Contains("Error"))
            {
                errorMessage = "An unexpected error occurred during login.";
                return;
            }

            if (result == "You have not Authority to login")
            {
                errorMessage = "You have not Authority to login";
                return;
            }

            if (result == "Invalid credentials")
            {
                errorMessage = "Invalid credentials";
                return;
            }

            if (result.Contains("You have logged in from another device"))
            {
                errorMessage = "You have logged in from another device. Please log in again.";
                return;
            }

            string token = result;

            await SaveLoginDataAsync(token);

            var handler = new JwtSecurityTokenHandler();
            var jwtToken = handler.ReadToken(token) as JwtSecurityToken;

            if (jwtToken != null)
            {
                var userIdClaim = jwtToken.Claims
                    .FirstOrDefault(c =>
                        c.Type == "http://schemas.xmlsoap.org/ws/2005/05/identity/claims/nameidentifier")
                    ?.Value;

                var userRole = jwtToken.Claims
                    .FirstOrDefault(c =>
                        c.Type == "http://schemas.microsoft.com/ws/2008/06/identity/claims/role")
                    ?.Value;

                if (int.TryParse(userIdClaim, out int userId))
                {
                    uid = userId;
                    UserService.SetUserId(userId);

#if MACCATALYST
                    // macOS permission flow should happen after successful login
                    // but before screenshot/audio tracking starts.
                    await RequestMacPermissionsBeforeTracking();
#endif

                    if (userRole?.ToLower() != "superadmin")
                    {
                        await DetermineTrackingStateAsync(userId, userRole);
                    }
                    else
                    {
                        Console.WriteLine("SuperAdmin detected - Skipping automatic tracking.");
                    }
                }
            }

            UserStateService.UserId = 0;
            UserStateService.SelectedUsername = null;
            UserStateService.SelectedAdminUsername = null;
            UserStateService.Admins = new();
            UserStateService.Users = new();
            UserStateService.SelectedUsageType = "all";
            UserStateService.SelectedDate = DateTime.Today;

            // The Users page is the single owner of starting tracking services.
            // Reset this for every successful login so auto-only users are started
            // exactly once and manual-capable users remain stopped until requested.
            App.first = true;
            NavigationManager.NavigateTo("/users");
        }
        catch (Exception ex)
        {
            errorMessage = $"An unexpected error occurred during login: {ex.Message}";
            message = null;
            Console.WriteLine(ex);
        }
    }

    private async Task SaveLoginDataAsync(string token)
    {
        Preferences.Set("authToken", token);
        Preferences.Set("auth_token", token);

#if MACCATALYST
        if (loginModel.rememberMe)
        {
            Preferences.Set("saved_username", loginModel.username);
        }
        else
        {
            Preferences.Remove("saved_username");
        }
#else
        await SecureStorage.SetAsync("auth_token", token);

        if (loginModel.rememberMe)
        {
            await SecureStorage.SetAsync("saved_username", loginModel.username);
        }
        else
        {
            SecureStorage.Remove("saved_username");
        }
#endif
    }

#if MACCATALYST
    private async Task RequestMacPermissionsBeforeTracking()
    {
        try
        {
            /*
             macOS cannot silently allow Screen Recording / System Audio Recording.
             The user must allow it from macOS Privacy settings.

             This method checks the actual permission state using CGPreflightScreenCaptureAccess()
             and AXIsProcessTrusted(), then guides the user to grant any missing permissions.
            */

            // 1. Check & request Screen Recording permission (needed for screenshots)
            bool screenRecordingOk = await ScreenTracker1.Platforms.MacCatalyst
                .DesktopScreenshotService.EnsureScreenRecordingPermissionAtLoginAsync();

            if (!screenRecordingOk)
            {
                Console.WriteLine("macOS: Screen Recording permission was not granted — screenshots will be disabled.");
            }
            else
            {
                Console.WriteLine("macOS: Screen Recording permission confirmed.");
            }

            // 2. Check & request Accessibility permission (needed for osascript app/window tracking)
            //    This uses the same AXIsProcessTrusted() check from Permissions.razor.
            //    osascript with System Events requires Accessibility to detect the active window title.
            bool accessibilityOk = await CheckMacAccessibilityPermissionAsync();

            if (!accessibilityOk)
            {
                Console.WriteLine("macOS: Accessibility permission was not granted — app/window titles may be incomplete.");
            }
            else
            {
                Console.WriteLine("macOS: Accessibility permission confirmed.");
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"macOS permission request error: {ex.Message}");
        }
    }

    private async Task<bool> CheckMacAccessibilityPermissionAsync()
    {
        // Use dlopen/dlsym to check AXIsProcessTrusted() without a direct framework reference
        try
        {
            const string axApiPath = "/System/Library/PrivateFrameworks/Accessibility.framework/Accessibility";
            IntPtr handle = dlopen(axApiPath, 0);
            if (handle == IntPtr.Zero) return false;

            try
            {
                IntPtr ptr = dlsym(handle, "AXIsProcessTrusted");
                if (ptr == IntPtr.Zero) return false;

                var del = Marshal.GetDelegateForFunctionPointer<AXIsProcessTrustedDelegate>(ptr);
                bool isTrusted = del();

                if (!isTrusted && Application.Current?.MainPage != null)
                {
                    bool openSettings = await Application.Current.MainPage.DisplayAlert(
                        "Accessibility Permission Required",
                        "ScreenTracker needs Accessibility permission to read active window titles.\n\nPlease enable it in System Settings > Privacy & Security > Accessibility and restart the app.",
                        "Open Settings",
                        "Continue"
                    );

                    if (openSettings)
                    {
                        await Launcher.Default.OpenAsync(
                            "x-apple.systempreferences:com.apple.preference.security?Privacy_Accessibility"
                        );
                    }
                }

                return isTrusted;
            }
            finally { dlclose(handle); }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Accessibility check error: {ex.Message}");
            return false;
        }
    }

    [DllImport("/usr/lib/libSystem.dylib")]
    private static extern IntPtr dlopen(string path, int mode);

    [DllImport("/usr/lib/libSystem.dylib")]
    private static extern IntPtr dlsym(IntPtr handle, string symbol);

    [DllImport("/usr/lib/libSystem.dylib")]
    private static extern int dlclose(IntPtr handle);

    [UnmanagedFunctionPointer(CallingConvention.Cdecl)]
    private delegate bool AXIsProcessTrustedDelegate();
#endif

    private async Task<bool> DetermineTrackingStateAsync(int userId, string? userRole)
    {
        try
        {
            var user = await UserService.GetUserByIdAsync(userId);

            if (user != null)
            {
                bool isManualTrackingAllowed = user.isManualTrackingEnabled.GetValueOrDefault(false);
                bool isAutoTrackingAllowed = user.isAutoTrackingEnabled.GetValueOrDefault(false);

                Console.WriteLine($"Login - User {userId} tracking permissions - Manual: {isManualTrackingAllowed}, Auto: {isAutoTrackingAllowed}");

                UserService.SetUserId(userId);

                if (isManualTrackingAllowed && !isAutoTrackingAllowed)
                {
                    Console.WriteLine("Login - Case 1: Manual-only tracking will start on the Users page");
                    Preferences.Set("IsOnState", true);
                }
                else if (!isManualTrackingAllowed && isAutoTrackingAllowed)
                {
                    Console.WriteLine("Login - Case 2: Automatic-only tracking will start on the Users page");
                    Preferences.Set("IsOnState", false);

                    var dailyTracker = await UserService.StartDailyTrackerAsync("automatic");
                    App.DailyTrackerStartedDuringAutoLogin = dailyTracker != null;
                }
                else if (isManualTrackingAllowed && isAutoTrackingAllowed)
                {
                    Console.WriteLine("Login - Case 3: Both modes available; starting automatic tracking");
                    Preferences.Set("IsOnState", false);

                    var dailyTracker = await UserService.StartDailyTrackerAsync("automatic");
                    App.DailyTrackerStartedDuringAutoLogin = dailyTracker != null;
                }
                else
                {
                    Console.WriteLine("Login - Case 4: No tracking permissions - Not starting tracking");

                    Preferences.Set("IsOnState", false);
                }

                return true;
            }
            else
            {
                Console.WriteLine($"Login - ERROR: Could not fetch user details for userId {userId}");
                return false;
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error in DetermineAndStartTracking: {ex.Message}");
            return false;
        }
    }

    private async Task StartAll(string startMode = "automatic")
    {
        // Tell the tracker which user is logged in so it uses the correct per-user file
        appUsageTrackerService.SetUserId(uid);

        try
        {
            appUsageTrackerService.Start(startMode);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error starting appUsageTrackerService: {ex.Message}");
        }

        try
        {
            desktopAutoCaptureService.Start(startMode);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error starting desktopAutoCaptureService: {ex.Message}");
        }

        try
        {
            afkTrackerService.Start(uid, startMode);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error starting afkTrackerService: {ex.Message}");
        }

        try
        {
            var dailyTracker = await UserService.StartDailyTrackerAsync(startMode);

            if (dailyTracker != null)
            {
                Console.WriteLine("Daily Tracker started successfully.");
            }
            else
            {
                Console.WriteLine("Error starting Daily Tracker.");
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error starting Daily Tracker: {ex.Message}");
        }
    }

    private async Task SignInWithGoogle()
    {
        try
        {
            string googleLoginUrl = $"{App.BaseUrl}/api/Auth/google-login";

            var authUrl = new Uri(googleLoginUrl);
            var callbackUrl = new Uri("screentracker://");

            var options = new WebAuthenticatorOptions
            {
                Url = authUrl,
                CallbackUrl = callbackUrl,
                PrefersEphemeralWebBrowserSession = true
            };

            var authResult = await WebAuthenticator.Default.AuthenticateAsync(options);

            // Add your Google token processing here if required.
        }
        catch (Exception ex)
        {
            errorMessage = "Connection error. Ensure your API is running and accessible.";
            Console.WriteLine($"Auth Error: {ex.Message}");
        }
    }
}
