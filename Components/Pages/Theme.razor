@page "/theme"
@inject NavigationManager NavigationManager
@inject IJSRuntime JSRuntime

<div class="theme-container">
    <div class="theme-section">
        <label class="theme-label">Theme Mode</label>

        <div class="theme-controls-row">
            <div class="theme-dropdown-wrapper">
                <select class="theme-dropdown" @onchange="OnThemeChanged">
                    <option value="system" selected="@(selectedTheme == "system")">🖥️ System Default</option>
                    <option value="dark" selected="@(selectedTheme == "dark")">🌙 Dark Mode</option>
                    <option value="light" selected="@(selectedTheme == "light")">☀️ Light Mode</option>
                </select>
            </div>

            <button class="theme-toggle-btn" @onclick="ToggleTheme" title="@(isDarkTheme ? "Switch to Light Theme" : "Switch to Dark Theme")">
                <i class="fas @themeIcon"></i>
            </button>
        </div>

        <div class="theme-indicator">
            <i class="fas @(isDarkTheme ? "fa-moon" : "fa-sun")"></i>
            <span>@(isDarkTheme ? "Dark Theme Active" : "Light Theme Active")</span>
        </div>
    </div>

    <button class="theme-back-btn" @onclick="BackToHome">
        <i class="fas fa-arrow-left"></i> Back to Home
    </button>
</div>

@code {
    private string themeIcon = "fa-sun";
    private bool isDarkTheme;
    private string selectedTheme = "system";
    private IJSObjectReference? themeModule;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            themeModule = await JSRuntime.InvokeAsync<IJSObjectReference>("import", "./js/theme.js");
            
            // Load saved theme preference
            var savedTheme = await themeModule.InvokeAsync<string>("getSavedThemePreference");
            if (!string.IsNullOrEmpty(savedTheme))
            {
                selectedTheme = savedTheme;
            }
            
            // Apply the current theme
            isDarkTheme = await themeModule.InvokeAsync<bool>("getSavedTheme");
            await UpdateThemeIcon();
            StateHasChanged();
        }
    }

    private async Task OnThemeChanged(ChangeEventArgs e)
    {
        if (e.Value != null)
        {
            selectedTheme = e.Value.ToString();
            
            // Save and apply the theme
            if (themeModule != null)
            {
                await themeModule.InvokeVoidAsync("saveThemePreference", selectedTheme);
                isDarkTheme = await themeModule.InvokeAsync<bool>("getSavedTheme");
                await UpdateThemeIcon();
            }
        }
    }

    private async Task ToggleTheme()
    {
        if (themeModule != null)
        {
            await themeModule.InvokeVoidAsync("toggleTheme");
            isDarkTheme = !isDarkTheme;
            
            // Update selected theme based on toggled state
            selectedTheme = isDarkTheme ? "dark" : "light";
            await UpdateThemeIcon();
        }
    }

    private async Task UpdateThemeIcon()
    {
        themeIcon = isDarkTheme ? "fa-moon" : "fa-sun";
    }

    private void BackToHome()
    {
        NavigationManager.NavigateTo("/users");
    }

    public async ValueTask DisposeAsync()
    {
        if (themeModule is not null)
        {
            await themeModule.DisposeAsync();
        }
    }
}