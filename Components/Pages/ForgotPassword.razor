@page "/forgot-password"

@using ScreenTracker1.Models
@using ScreenTracker1.Services
@inject LoginService LoginService
@inject NavigationManager NavigationManager
@layout ScreenTracker1.Components.Layout.NoNavLayout

<div class="forgot-password-page">
    <!-- Header -->
    <div class="fp-header">
        <button class="fp-back-btn" @onclick="GoBack">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M19 12H5M12 19l-7-7 7-7"/>
            </svg>
        </button>
        <h1 class="fp-title">Reset Password</h1>
    </div>

    <!-- Main Content -->
    <div class="fp-content">
        <!-- Illustration -->
        <div class="fp-illustration">
            <img src="https://img.freepik.com/premium-vector/password-reset-icon-apps-vector_116137-6219.jpg?w=740"
                 alt="Forgot Password Illustration"
                 class="fp-image" />
        </div>

        @if (!otpSent)
        {
            <div class="fp-text-content">
                <h2 class="fp-heading">Forgot Password?</h2>
                <p class="fp-subtitle">No worries! Enter your email address below and we'll send a code to reset your password.</p>
            </div>

            <EditForm Model="@otpRequest" OnValidSubmit="@HandleForgotPassword" class="fp-form">
                <DataAnnotationsValidator />
                <ValidationSummary />

                <div class="fp-form-group">
                    <label class="fp-label">EMAIL ADDRESS</label>
                    <div class="fp-input-wrapper">
                        <InputText @bind-Value="otpRequest.Email" type="email" class="fp-input" placeholder="example@company.com" />
                        <svg class="fp-input-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#9aa0a6" stroke-width="2">
                            <rect x="2" y="5" width="20" height="14" rx="2"/>
                            <polyline points="2,5 12,13 22,5"/>
                        </svg>
                    </div>
                    <p class="fp-privacy-text">We will never share your email with anyone else.</p>
                </div>

                <button type="submit" class="fp-submit-btn">
                    Send OTP
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <polyline points="9,18 15,12 9,6"/>
                    </svg>
                </button>
            </EditForm>
        }
        else
        {
            <div class="fp-text-content">
                <h2 class="fp-heading">Verify Code</h2>
                <p class="fp-subtitle">Enter the OTP code sent to your email and your new password.</p>
            </div>

            <EditForm Model="@verifyOtpRequest" OnValidSubmit="@HandleForgotPassword" class="fp-form">
                <DataAnnotationsValidator />
                <ValidationSummary />

                <div class="fp-form-group">
                    <label class="fp-label">OTP CODE</label>
                    <InputText @bind-Value="verifyOtpRequest.otp" class="fp-input" placeholder="Enter OTP code" />
                </div>

                <div class="fp-form-group">
                    <label class="fp-label">NEW PASSWORD</label>
                    <InputText @bind-Value="verifyOtpRequest.newPassword" type="password" class="fp-input" placeholder="Enter new password" />
                </div>

                <button type="submit" class="fp-submit-btn">
                    Verify & Reset
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <polyline points="9,18 15,12 9,6"/>
                    </svg>
                </button>
            </EditForm>
        }

        @if (!string.IsNullOrEmpty(message))
        {
            <p class="fp-message @(message.Contains("success") ? "fp-success" : "fp-error-text")">@message</p>
        }
    </div>
</div>

@code {
    private bool otpSent = false;
    private string message;
    private OtpRequestModel otpRequest = new();
    private VerifyOtpRequestModel verifyOtpRequest = new();

    private async Task HandleForgotPassword()
    {
        if (!otpSent)
        {
            message = await LoginService.SendOtpAsync(otpRequest);
            if (message.Contains("successfully"))
            {
                otpSent = true;
                verifyOtpRequest.email = otpRequest.Email;
            }
        }
        else
        {
            message = await LoginService.VerifyOtpAsync(verifyOtpRequest);
            if (message.Contains("successful"))
            {
                SecureStorage.Remove("auth_token");
                Preferences.Remove("authToken");

                NavigationManager.NavigateTo("/login");
            }
        }
    }

    private void GoBack()
    {
        NavigationManager.NavigateTo("/login");
    }
}