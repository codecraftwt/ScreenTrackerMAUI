@page "/forgot-password"

@using ScreenTracker1.Models
@using ScreenTracker1.Services
@inject LoginService LoginService
@inject NavigationManager NavigationManager
@layout ScreenTracker1.Components.Layout.NoNavLayout

<div class="forgot-password-container">
    <div class="form-container">
        <h2 class="text-center mb-4">Forgot Password</h2>

        @if (!otpSent)
        {
            <EditForm Model="@otpRequest" OnValidSubmit="@HandleForgotPassword">
                <DataAnnotationsValidator />
                <ValidationSummary />

                <div class="form-group">
                    <label>Email</label>
                    <InputText @bind-Value="otpRequest.Email" type="email" class="input" />
                </div>

                <div class="form-group">
                    <button type="submit" class="submit-btn">Send OTP</button>
                </div>
            </EditForm>
        }
        else
        {
            <EditForm Model="@verifyOtpRequest" OnValidSubmit="@HandleForgotPassword">
                <DataAnnotationsValidator />
                <ValidationSummary />

                <div class="form-group">
                    <label>OTP Code</label>
                    <InputText @bind-Value="verifyOtpRequest.otp" class="input" />
                </div>

                <div class="form-group">
                    <label>New Password</label>
                    <InputText @bind-Value="verifyOtpRequest.newPassword" type="password" class="input" />
                </div>

                <div class="form-group">
                    <button type="submit" class="submit-btn">Verify & Reset</button>
                </div>
            </EditForm>
        }

        <p class="text-center mt-2">
            <a href="/login">Back to Login</a>
        </p>

        @if (!string.IsNullOrEmpty(message))
        {
            <p class="message">@message</p>
        }
    </div>
</div>

@code {
    private bool otpSent = false;
    private string message;
    private OtpRequestModel otpRequest = new();
    private VerifyOtpRequestModel verifyOtpRequest = new();

    private async Task HandleForgotPassword()
    {
        if (!otpSent)
        {
            message = await LoginService.SendOtpAsync(otpRequest);
            if (message.Contains("successfully"))
            {
                otpSent = true;
                verifyOtpRequest.email = otpRequest.Email;
            }
        }
        else
        {
            message = await LoginService.VerifyOtpAsync(verifyOtpRequest);
            if (message.Contains("successful"))
            {
                SecureStorage.Remove("auth_token");
                Preferences.Remove("authToken");

                NavigationManager.NavigateTo("/login");
            }
        }
    }
}