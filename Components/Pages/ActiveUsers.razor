@page "/active-users"
@inject UserService UserService
@inject NavigationManager NavigationManager
@inject IJSRuntime JSRuntime  // For working with LocalStorage or SessionStorage
@inject SessionKeepAliveService SessionKeepAliveService
@using ScreenTracker1.Models
@using System.Linq
@using System.IdentityModel.Tokens.Jwt
@using ScreenTracker1.Services
@implements IDisposable

@if (activeUsers == null)
{
    <p class="loading">Loading active users...</p>
}
else if (!activeUsers.Any())
{
    <p class="no-users">No active users found.</p>
}
else
{
    <div class="users-grid">
        @foreach (var user in activeUsers)
        {
            <div class="user-card" @onclick="() => OnCardClickAsync(user.id)">
                <div class="user-header">
                     <span class="user-avatar">@user.firstName[0]@user.lastName[0]</span>
                    <div>
                        <h4>@user.firstName @user.lastName</h4>
                        <p class="role">@user.role</p>
                    </div>
                </div>
                <div class="user-info">
                    <p><strong>Username:</strong> @user.username</p>
                    <p><strong>Email:</strong> @user.email</p>
                </div>
            </div>
        }
    </div>
}

@code {
    private List<User>? activeUsers;
    private int? CurrentAdminId { get; set; } 
    private string? UserRole { get; set; }
    private PeriodicTimer? _timer;
    private CancellationTokenSource? _cts;

    protected override async Task OnInitializedAsync()
    {
        var token = Preferences.Get("authToken", null);

        if (string.IsNullOrEmpty(token))
        {
            Console.WriteLine("Token not found or expired");
            return;
        }

        try
        {
            var handler = new JwtSecurityTokenHandler();
            var jsonToken = handler.ReadToken(token) as JwtSecurityToken;

            if (jsonToken != null)
            {
                // Check and refresh token if expired (handles Mac sleep/wake)
                await SessionKeepAliveService.CheckAndRefreshNowAsync();

                var userIdClaim = jsonToken.Claims.FirstOrDefault(c => c.Type == "http://schemas.xmlsoap.org/ws/2005/05/identity/claims/nameidentifier");
                if (userIdClaim != null) CurrentAdminId = int.Parse(userIdClaim.Value);

                var roleClaim = jsonToken.Claims.FirstOrDefault(c => c.Type == "http://schemas.microsoft.com/ws/2008/06/identity/claims/role");
                UserRole = roleClaim?.Value?.ToLower();

                if (CurrentAdminId.HasValue)
                {
                    var adminIdParam = UserRole == "superadmin" ? null : CurrentAdminId;
                    activeUsers = await UserService.GetActiveSessionsAsync(adminIdParam);
                }
            }

            _cts = new CancellationTokenSource();
            _timer = new PeriodicTimer(TimeSpan.FromSeconds(30));
            _ = PollActiveUsersAsync(_cts.Token);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error: {ex.Message}");
            activeUsers = new List<User>();
        }
    }

    private async Task PollActiveUsersAsync(CancellationToken ct)
    {
        while (await _timer!.WaitForNextTickAsync(ct))
        {
            try
            {
                var adminIdParam = UserRole == "superadmin" ? null : CurrentAdminId;
                var users = await UserService.GetActiveSessionsAsync(adminIdParam, suppressUnauthorized: true);
                activeUsers = users ?? new List<User>();
                await InvokeAsync(StateHasChanged);
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Error polling active users: {ex.Message}");
            }
        }
    }

    public void Dispose()
    {
        _cts?.Cancel();
        _cts?.Dispose();
        _timer?.Dispose();
    }

    private async Task OnCardClickAsync(int userId)
    {
        NavigationManager.NavigateTo($"/userreport/{userId}");
    }
}
