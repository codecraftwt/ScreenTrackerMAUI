 @page "/users"
@layout MainLayout
@inject UserService UserService
@inject IJSRuntime JSRuntime
@using ScreenTracker1.Models
@using ScreenTracker1.Services
@using System.Text.Json
@using ScreenTracker1.DTOS
@using Microsoft.JSInterop;
@using System.IdentityModel.Tokens.Jwt;
@using ScreenTracker1.Components.Layout
@inject NavigationManager NavigationManager
@inject DesktopAutoCaptureService desktopAutoCaptureService
@inject AfkTrackerService afkTrackerService
@inject SystemThemeService SystemThemeService
@inject AppUsageTracker appUsageTrackerService
@inject UserSelectionStateService UserStateService
@using NEvaldas.Blazor.Select2
@using System.Diagnostics
@using System.Linq
@* <NavMenu OnLogoutTriggered="PerformLogout" />
@layout ScreenTracker1.Components.Layout.NoNavLayout *@

<div class="p-4" style="min-height: 100vh;">
    @if (isAdmin)
    {
        @if (users == null && admins == null && (userRole?.ToLower() == "admin" || userRole?.ToLower() == "superadmin"))
        {
            <p><em>Loading admin/user lists...</em></p>
        }
        else
        {
            <div class="selectbox">
                @if (userRole?.ToLower() == "superadmin")
                {
                    <div class="toolbar-section">
                        <label class="label">Select Admin</label>
                        <div class="tooltip-container">
                            <select id="admin-select" @onchange="OnSelectedAdminChanged" class="stitch-user-select" value="@selectedAdminUsername">
                                <option value="">Select Admin</option>
                                @foreach (var admin in admins?.Where(a => a.role?.ToLower() != "superadmin"))
                                {
                                    <option value="@admin.username">@admin.username</option>
                                }
                            </select>
                            @*  <span class="tooltip-text tooltip-bottom">Choose an admin from the list</span> *@
                        </div>
                    </div>

                    @if (users != null && users.Count > 0)
                    {
                        <div class="toolbar-section toolbar-section-select-user">
                            <label class="label">Select User</label>
                            <div class="tooltip-container">
                                <select id="user-select" @onchange="OnSelectedUserChanged" class="stitch-user-select ms-2" value="@selectedUsername">
                                    <option value="">Select User</option>
                                    @foreach (var user in users)
                                    {
                                        <option value="@user.username">@user.username</option>
                                    }
                                </select>
                                <span class="tooltip-text tooltip-bottom">Choose a user from the list</span>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <div class="toolbar-section">
                        <label class="label">Select User</label>
                        <div class="tooltip-container">
                            <select id="user-select-admin" @onchange="OnSelectedUserChanged" class="stitch-user-select" value="@selectedUsername">
                                <option value="">Select a user</option>

                                @foreach (var user in users)
                                {
                                    <option value="@user.username">@user.username</option>
                                }
                            </select>
                            <span class="tooltip-text tooltip-bottom">Choose a user from the list</span>
                        </div>
                    </div>
                }

                @if (userId > 0)
                {
                    <div class="toolbar-section">
                        <label class="label label-usage-type">Usage Type</label>
                        <div class="tooltip-container">
                            <select id="usage-type-select" @onchange="OnUsageTypeChanged" class="stitch-user-select ms-2" value="@selectedUsageType">
                                <option value="all">All</option>
                                <option value="manual">Manual</option>
                                <option value="automatic">Automatic</option>
                            </select>
                            <span class="tooltip-text tooltip-bottom">Filter data by usage type</span>
                        </div>
                    </div>
                }
            </div>
        }
    }

    @if (userId != null && userId > 0)
    {
        @* Debug: Show userId value - VISIBLE FOR TESTING *@
        @*   <div style="background:yellow; padding:10px; margin:10px; border:2px solid red;">
    <strong>DEBUG INFO:</strong><br/>
    userId = @userId<br/>
    loggedInUserId = @loggedInUserId<br/>
    selectedUsername = @selectedUsername<br/>
    userRole = @userRole<br/>
    isManualTrackingAllowed = @isManualTrackingAllowed<br/>
    isAutoTrackingAllowed = @isAutoTrackingAllowed<br/>
    ShouldShowTrackingButton() = @ShouldShowTrackingButton()<br/>
    isOn = @isOn
    </div> *@

        <div class="stitch-container">
            <div class="toolbar-container grid-toolbar">

                <div class="toolbar-left toolbar-AutoRefresh">
                    <div class="tooltip-container mr-4">
                        <input type="date"
                               @onchange="OnDateChanged"
                               value="@selectedDate.ToString("yyyy-MM-dd")"
                               max="@maxSelectableDate"
                               class="stitch-date-picker" />
                        <span class="tooltip-text">Select a Date</span>
                    </div>

                    <div class="tooltip-container-Auto-Refresh">
                        <label class="label mr-2 label-Auto-Refresh">Auto Refresh</label>
                        <select class="stitch-dropdown" @onchange="OnIntervalChanged" value="@selectedInterval">
                            <option value="0">Off</option>
                            <option value="10">10s</option>
                            <option value="20">20s</option>
                            <option value="30">30s</option>
                        </select>
                        <span class="tooltip-text tooltip-text-Auto-Refresh">Interval to refresh</span>
                    </div>
                </div>

                <div class="toolbar-center">
                    @if (ShouldShowTrackingButton())
                    {
                        <div class="toolbar-section toolbar-section-tracker">
                            <label class="label">Tracking Status</label>
                            <div class="tooltip-container">
                                <button class="tracking-toggle @(isOn ? "tracking-on" : "tracking-off")"
                                        @onclick="OnToggleStateClicked"
                                        disabled="@IsTrackingButtonDisabled()"
                                        aria-label="Toggle tracking state">
                                    @if (isOn)
                                    {
                                        <span class="tracking-indicator tracking-active"></span>
                                        <span class="tracking-text">ON</span>
                                    }
                                    else
                                    {
                                        <span class="tracking-indicator"></span>
                                        <span class="tracking-text">OFF</span>
                                    }
                                </button>
                                <span class="tooltip-text">@GetTrackingTooltip()</span>
                            </div>
                        </div>
                    }
                </div>

                <div class="toolbar-right">
                    <div class="btn-group" role="group" aria-label="Toolbar Actions">
                        <div class="tooltip-container mr-2">
                            <button class="stitch-refresh-btn btn btn-primary" style="background-color:#912bb9; border-radius: 8px;" @onclick="OnRefreshClicked">
                                <i class="fas fa-sync-alt me-2"></i> Refresh
                            </button>
                            <span class="tooltip-text">Refresh page</span>
                        </div>
                        <div class="tooltip-container">
                            <button class="stitch-refresh-btn btn btn-primary" style="background-color:#592cab; border-radius: 8px;" @onclick="OnViewScreenshotsClicked">
                                <i class="bi bi-camera me-2"></i> Screen
                            </button>
                            <span class="tooltip-text">Screenshots</span>
                        </div>
                    </div>
                </div>
            </div>





            <div class="chart-container">
                @if (isChartLoading)
                {
                    <div class="card p-3 rounded-3 shadow-sm placeholder-glow" style="min-height:350px; width:100%">
                        <h4 class="card-title"><span class="placeholder col-8"></span></h4>
                        <p class="card-text"><span class="placeholder col-12"></span></p>
                        <p class="card-text"><span class="placeholder col-10"></span></p>
                        <div style="height:200px">
                            <span class="placeholder col-12 h-100"></span>
                        </div>
                    </div>
                }
                else
                {
                    <div class="chart-wrapper">
                    <canvas id="barChart" class="stitch-chart"></canvas>
                </div>

                }
                <div class="dashboard-grid-container">

                    <div class="login-card-item">
                        <div class="dashboard-card login-card h-100">
                            <div class="card-header">
                                <span class="card-icon"><i class="fas fa-sign-in-alt"></i></span>
                                <span class="card-title">Login At</span>
                                <span class="card-options">...</span>
                            </div>
                            <div class="card-body">
                                <div class="main-value">@LoginTime</div>
                                <div class="sub-text">Time of Day</div>
                            </div>
                        </div>
                    </div>

                    <div class="stats-grid-container">
                        @if (isAfkDataLoading)
                        {
                            <div class="stat-card-item">
                                <div class="dashboard-card">
                                </div>
                            </div>
                            <div class="stat-card-item">
                                <div class="dashboard-card">
                                </div>
                            </div>
                            <div class="stat-card-item">
                                <div class="dashboard-card">
                                </div>
                            </div>
                            <div class="stat-card-item">
                                <div class="dashboard-card">
                                </div>
                            </div>
                        }
                        else
                        {
                            <div class="stat-card-item">
                                <div class="dashboard-card dashboard-card-voilet">
                                    <div class="card-header">
                                        <span class="card-icon"><i class="fas fa-hourglass-half"></i></span>
                                        <span class="card-title">Ideal Time</span>
                                        <span class="card-options">...</span>
                                    </div>
                                    <div class="card-body">
                                        <div class="main-value">@FormatDuration(totalAfkMinutes)</div>
                                        <div class="sub-text">Time Away from Keyboard</div>
                                    </div>
                                </div>
                            </div>

                            <div class="stat-card-item">
                                <div class="dashboard-card active-card dashboard-card-pink-voilet">
                                    <div class="card-header">
                                        <span class="card-icon"><i class="fas fa-running"></i></span>
                                        <span class="card-title">Active Time</span>
                                        <span class="card-options">...</span>
                                    </div>
                                    <div class="card-body">
                                        <div class="main-value">@FormatDuration(totalTimeInMinutes - totalAfkMinutes)</div>
                                        <div class="sub-text">Time On Task</div>
                                    </div>
                                </div>
                            </div>

                            <div class="stat-card-item">
                                <div class="dashboard-card dashboard-card-voilet">
                                    <div class="card-header">
                                        <span class="card-icon"><i class="fas fa-clock"></i></span>
                                        <span class="card-title">Total Time</span>
                                        <span class="card-options">...</span>
                                    </div>
                                    <div class="card-body">
                                        <div class="main-value">@FormatDuration(totalTimeInMinutes)</div>
                                        <div class="sub-text">Total Shift Duration</div>
                                    </div>
                                </div>
                            </div>

                            <div class="stat-card-item">
                                <div class="dashboard-card dashboard-card-pink-voilet">
                                    <div class="card-header">
                                        <span class="card-icon"><i class="fas fa-sign-in-alt"></i></span>
                                        <span class="card-title">Check-in Time</span>
                                        <span class="card-options">...</span>
                                    </div>
                                    <div class="card-body">
                                        @if (string.IsNullOrEmpty(CheckinTime))
                                        {
                                            <div class="main-value">0h 0m 0s</div>
                                        }
                                        else
                                        {
                                            <div class="main-value">@CheckinTime</div>
                                        }
                                        <div class="sub-text">Time of Day</div>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>

            <div class="stitch-tabs">
                <div class="stitch-tab @(selectedTab == "summary" ? "active" : "")" @onclick='() => SelectTab("summary")'>Summary</div>
                 @* <div class="stitch-tab @(selectedTab == "window" ? "active" : "")" @onclick='() => SelectTab("window")'>Window</div> *@
            </div>

            <div class="stitch-tab-content">
                @if (selectedTab == "summary")
                {
                    <div class="stitch-summary-grid">
                        <section class="stitch-card">
                            <h4>Top Applications</h4>
                            @if (isAppUsageLoading)
                            {
                                <div class="card p-3 placeholder-glow">
                                    <h4 class="placeholder-glow"><span class="placeholder col-8"></span></h4>
                                    <div class="placeholder-glow my-2"><span class="placeholder col-10"></span></div>
                                    <div class="placeholder-glow my-2"><span class="placeholder col-12"></span></div>
                                    <div class="placeholder-glow my-2"><span class="placeholder col-9"></span></div>
                                </div>
                            }
                            else if (appUsageList != null && appUsageList.Any())
                            {
                                var totalAppTime = appUsageList.Sum(a => a.durationInMinutes);
                                foreach (var app in appUsageList)
                                {
                                    var percent = (app.durationInMinutes / totalAppTime) * 100;
                                    <div class="stitch-bar" @onclick="() => OnAppClick(app.appName)">
                                        <div style="width:@percent%;background-color:@GetDynamicColor(app.appName);height:100%;"></div>
                                        <div class="progress-bar-fill" style="width:@percent%;background-color:@GetDynamicColor(app.appName);"></div>

                                        @* NEW: Use bar-content wrapper for better icon alignment *@
                                        <div class="bar-content">
                                            <span class="label app-label-content">
                                                @* CHANGED: Use <img> because GetAppIconClass now returns image data, not a CSS class *@
                                                <img src="@GetAppIconClass(app.appName)"
                                                     alt="icon"
                                                     class="app-icon"
                                                     style="width: 20px; height: 20px; margin-right: 8px; vertical-align: middle; object-fit: contain;" />

                                                @app.appName
                                            </span>
                                            <span class="time">@FormatDuration(app.durationInMinutes)</span>
                                        </div>
                                    </div>
                                }
                                <div class="stitch-button-row">
                                    @if (moreAppUsageAvailable)
                                    {
                                        <button class="stitch-btn" @onclick="LoadMoreAppUsage">
                                            @*          <i class="fas fa-plus"></i> Show More *@
                                            @*         <i class="fas fa-arrow-down"></i> Show More
                            <i class="fas fa-chevron-down"></i> Show More *@
                                            <i class="fas fa-plus-circle"></i> Show More
                                            @*   <i class="fas fa-expand"></i> Show More *@
                                        </button>
                                    }
                                    @if (currentAppUsagePage > 1)
                                    {
                                        <button class="stitch-btn" @onclick="ShowLessAppUsage">
                                            @*         <i class="fas fa-minus"></i> Show Less *@
                                            @*       <i class="fas fa-arrow-up"></i> Show Less *@
                                            @*   <i class="fas fa-arrow-up"></i> Show Less *@
                                            <i class="fas fa-minus-circle"></i> Show Less
                                        </button>
                                    }
                                </div>

                            }
                            else
                            {
                                <p>No applications to display.</p>
                            }
                        </section>

                        @if (!string.IsNullOrEmpty(selectedAppName))
                        {
                            <section class="stitch-card">
                                <h4>Top Window Titles "@selectedAppName"</h4>
                                @if (appTitleList != null && appTitleList.Any())
                                {
                                    var totalTitleTime = appTitleList.Sum(t => t.durationInMinutes);
                                    <div class="title-list-container">
                                        @{
                                            var titleIndex = 0;
                                        }
                                     @*     @foreach (var title in appTitleList)
                                         {
                                             var percent = (title.durationInMinutes / totalTitleTime) * 100;
                                             var isFirst = titleIndex == 0;
                                             <div class="stitch-bar @(isFirst ? "first-bar" : "")">
                                                 <div style="width:@percent%;background-color:@GetDynamicColor(title.title);height:100%;"></div>
                                                 <span class="label" data-tooltip="@title.title">@title.title</span>
                                                 <span class="time">@FormatDuration(title.durationInMinutes)</span>
                                             </div>
                                             titleIndex++;
                                         } *@

                                        @foreach (var title in appTitleList)
                                        {
                                            var percent = (title.durationInMinutes / totalTitleTime) * 100;
                                            var isFirst = titleIndex == 0;
                                            <div class="stitch-bar @(isFirst ? "first-bar" : "")">
                                                <div style="width:@percent%;background-color:@GetDynamicColor(title.title);height:100%;"></div>
                                                <span class="label" data-tooltip="@title.title"><span class="label-text">@title.title</span></span>
                                                <span class="time">@FormatDuration(title.durationInMinutes)</span>
                                            </div>
                                            titleIndex++;
                                        }
                                    </div>
                                    <div class="stitch-button-row">
                                        @if (appTitleList.Count >= titlePageSize && moreTitlesAvailable)
                                        {
                                            <button class="stitch-btn" @onclick="LoadMoreTitles">
                                                <i class="fas fa-plus-circle"></i>
                                                Show More
                                            </button>

                                        }
                                        @if (currentTitlePage > 1)
                                        {
                                            <button class="stitch-btn" @onclick="ShowLessTitles"> <i class="fas fa-minus-circle"></i> Show Less</button>
                                        }
                                    </div>
                                }
                                else
                                {
                                    <p>No window titles available for this date.</p>
                                }
                            </section>

                            <section class="stitch-card">
                                <h4>Top Categories for "@selectedAppName"</h4>
                                @if (categoryKeywordGroups != null && categoryKeywordGroups.Any())
                                {
                                    var totalCategoryTime = categoryKeywordGroups.Sum(c => c.totalDurationInMinutes);
                                    foreach (var category in categoryKeywordGroups)
                                    {
                                        var percent = (category.totalDurationInMinutes / totalCategoryTime) * 100;
                                        <div class="stitch-bar">
                                            <div style="width:@percent%;background-color:@GetDynamicColor(category.category);height:100%;"></div>
                                            <span class="label">@category.category</span>
                                        </div>
                                    }
                                    <div class="stitch-button-row">
                                        @if (categoryKeywordGroups.Count >= 5 || categoryKeywordGroups.Count < totalCategoryRecords)
                                        {
                                            <button class="stitch-btn" @onclick="LoadMoreCategories">Show More</button>
                                        }
                                        @if (currentCategoryPage > 1)
                                        {
                                            <button class="stitch-btn" @onclick="ShowLessCategories">Show Less</button>
                                        }
                                    </div>
                                }
                                else
                                {
                                    <p>No category data available for this date.</p>
                                }
                            </section>
                        }
                    </div>
                }

            </div>
        </div>
    }
</div>

