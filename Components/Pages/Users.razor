    private async Task LoadDataAsync(int id)
    {
        isChartLoading = true;
        StateHasChanged();
        try
        {
            var appUsageData = await UserService.GetAppUsageDataAsync(id, selectedUsageType, userRole);
            var aggregateResponse = await UserService.GetDailyTrackerAggregateAsync(userId, selectedDate, selectedUsageType);

            totalTimeInMinutes = aggregateResponse.TotalDurationMinutes;
            var appTitleListResult = await UserService.GetAppTitleByDateAsync(selectedDate, id);
            appTitleList = appTitleListResult;

            // Prepare all three data lists using the numerical properties
            labels = appUsageData.Select(x => x.date).ToList();
            totalData = appUsageData.Select(x => x.totalDurationInMinutes).ToList();

            // **IMPORTANT:** Using the helper properties that return numerical minutes
            afkData = appUsageData.Select(x => x.AfkDurationInMinutes).ToList();
            activeData = appUsageData.Select(x => x.ActiveDurationInMinutes).ToList();

            // OVERRIDE: For the selected date, use the same aggregate data as the summary cards
            string selectedDateStr = selectedDate.ToString("yyyy-MM-dd");
            int selectedDateIndex = labels.FindIndex(l => l == selectedDateStr);
            if (selectedDateIndex >= 0)
            {
                // Replace chart data with aggregate values for the selected date
                totalData[selectedDateIndex] = totalTimeInMinutes;
                // Active time = Total - AFK (will be updated after LoadAfkDataAsync completes)
                // For now, calculate with current afkData value or 0 if not loaded yet
                double afkForSelectedDate = selectedDateIndex < afkData.Count ? afkData[selectedDateIndex] : 0;
                activeData[selectedDateIndex] = Math.Max(0, totalTimeInMinutes - afkForSelectedDate);
            }

            // Set the flag to indicate data is ready for charting
            chartDataReady = true;
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error fetching data: {ex.Message}");
            labels.Clear();
            totalData.Clear();
            afkData.Clear();
            activeData.Clear();
            // data.Clear(); // <-- Removed old single data variable
            // appUsageList = null; // Assuming appUsageList is a list of AppUsageData
        }
        finally
        {
            isChartLoading = false;
            StateHasChanged(); // This triggers OnAfterRenderAsync
        }
    }
