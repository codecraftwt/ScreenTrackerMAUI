    protected override async Task OnInitializedAsync()
    {
        await base.OnInitializedAsync();
        UserService.SetNavigationManager(NavigationManager);

        token = Preferences.Get("authToken", null);
        userRole = null;
        loggedInUserId = 0;

        if (!string.IsNullOrEmpty(token))
        {
            var handler = new JwtSecurityTokenHandler();
            var jwtToken = handler.ReadToken(token) as JwtSecurityToken;
            if (jwtToken != null)
            {
                UserName = jwtToken?.Claims.FirstOrDefault(c => c.Type == "http://schemas.xmlsoap.org/ws/2005/05/identity/claims/name")?.Value;
                userRole = jwtToken?.Claims.FirstOrDefault(c => c.Type == "http://schemas.microsoft.com/ws/2008/06/identity/claims/role")?.Value;
                isAdmin = userRole?.ToLower() == "admin" || userRole?.ToLower() == "superadmin";
                var userIdClaim = jwtToken?.Claims.FirstOrDefault(c => c.Type == "http://schemas.xmlsoap.org/ws/2005/05/identity/claims/nameidentifier")?.Value;

                if (int.TryParse(userIdClaim, out loggedInUserId))
                {
                    this.userId = loggedInUserId;
                }

                var loginTimeClaim = jwtToken.Claims.FirstOrDefault(c => c.Type == "LoginTime")?.Value;
                if (!string.IsNullOrEmpty(loginTimeClaim))
                {
                    LoginTime = loginTimeClaim;
                }
            }
        }

        if (UserStateService.UserId > 0)
        {
            this.userId = UserStateService.UserId;
            this.selectedUsername = UserStateService.SelectedUsername;
            this.selectedAdminUsername = UserStateService.SelectedAdminUsername;
            this.selectedUsageType = UserStateService.SelectedUsageType;
            this.selectedDate = UserStateService.SelectedDate;

            admins = UserStateService.Admins;
            users = UserStateService.Users;

            await LoadDataAsync(this.userId);
            await LoadAppUsageData();
            await LoadAfkDataAsync(this.userId);
             await LoadCheckinTime(userId);
            await UpdateChart();

        }
        else
        {
            if (isAdmin && userRole?.ToLower() == "superadmin")
            {
                admins = await UserService.GetAdminsWithUsersAsync(loggedInUserId);
                UserStateService.Admins = admins;
                isChartLoading = false;
                isAppUsageLoading = false;
                isAfkDataLoading = false;
            }
            else if (isAdmin)
            {
                users = await UserService.GetAllUsersByAdminAsync(this.userId, userRole);
                UserStateService.Users = users;
                isChartLoading = false;
                isAppUsageLoading = false;
                isAfkDataLoading = false;
            }
            else
            {
                await LoadDataAsync(this.userId);
                await LoadAppUsageData();
                await LoadAfkDataAsync(this.userId);
                await LoadCheckinTime(userId);
                await UpdateChart();
            }
        }
    }

