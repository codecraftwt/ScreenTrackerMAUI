    private List<double> afkData = new List<double>();
    private List<double> activeData = new List<double>();
    private bool chartDataReady = false;

    [JSInvokable]
    public async Task OnSelect2Changed(string elementId, string value)
    {
        if (elementId == "admin-select")
        {
            selectedAdminUsername = value;
            UserStateService.SelectedAdminUsername = selectedAdminUsername;
            selectedAdmin = admins.FirstOrDefault(a => a.username == selectedAdminUsername);
            users = new List<User>();
            selectedUsername = null;
            selectedUser = null;
            userId = 0;
            appUsageList = null;
            appTitleList = null;
            isSelect2UserInitialized = false;
            UserStateService.Users = users;
            UserStateService.SelectedUsername = null;
            UserStateService.UserId = 0;

            // 👇 FIX: Reset Usage Type Select2 flag when admin changes and user dropdown is cleared
            isSelect2UsageTypeInitialized = false;

            if (selectedAdmin != null)
            {
                users = await UserService.GetAllUsersByAdminAsync(selectedAdmin.id, "admin");
                UserStateService.Users = users;
            }
        }
        else if (elementId == "user-select" || elementId == "user-select-admin")
        {
            UserStateService.SelectedUsername = value;
            selectedUsername = UserStateService.SelectedUsername;
            selectedUser = users.FirstOrDefault(u => u.username == selectedUsername);

            if (selectedUser != null)
            {
                App.SelectedUserId = selectedUser.id;
                userId = selectedUser.id;
                UserStateService.UserId = userId;
                LoginTime = await UserService.GetUserLoginTimeFormattedAsync(userId);

                // No need to reset the flag here, as it will be initialized in OnAfterRenderAsync
                // if it hasn't been already.

                await Task.WhenAll(
                    LoadDataAsync(userId),
                    LoadAppUsageData(),
                    LoadAfkDataAsync(userId),
                    LoadCheckinTime(userId)

                );

                await UpdateChart();
            }
            else
            {
                App.SelectedUserId = 0;
                userId = 0;
                UserStateService.UserId = 0;
                appUsageList = null;
                appTitleList = null;
                UserStateService.SelectedUsername = null;

                // 👇 FIX: Reset Usage Type Select2 flag when user selection is cleared (dropdown is hidden)
                isSelect2UsageTypeInitialized = false;
            }
        }
        else if (elementId == "usage-type-select")
        {
            selectedUsageType = value;
            UserStateService.SelectedUsageType = selectedUsageType;

            selectedAppName = null;

            await LoadDataAsync(userId);

            await LoadAppUsageData();
            await LoadAfkDataAsync(userId);
            await UpdateChart();
            await LoadCheckinTime(userId);
        }
        StateHasChanged();
    }

