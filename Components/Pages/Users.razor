    private string GetAppIconClass(string appName)
    {

        string exePath = GetPathFromName(appName); 

        try
        {
            using (System.Drawing.Icon icon = System.Drawing.Icon.ExtractAssociatedIcon(exePath))
            {
                using (System.Drawing.Bitmap bitmap = icon.ToBitmap())
                {
                    using (System.IO.MemoryStream ms = new System.IO.MemoryStream())
                    {
                        bitmap.Save(ms, System.Drawing.Imaging.ImageFormat.Png);
                        byte[] byteImage = ms.ToArray();
                        // Returns the Base64 string directly
                        return "data:image/png;base64," + Convert.ToBase64String(byteImage);
                    }
                }
            }
        }
        catch
        {
            // Fallback to a default generic icon URL or a FontAwesome class if you prefer
            return "/images/default-app.png";
        }
    }

    private string GetPathFromName(string appName)
    {
        try
        {
            // 1. Get the real process name (e.g., "Visual Studio" -> "devenv")
            // Accessing the static dictionary from your other class:
            var entry = AppUsageTracker._friendlyAppNames
                .FirstOrDefault(x => x.Value.Equals(appName, StringComparison.OrdinalIgnoreCase));

            // Fix the .Key error: if entry is default/null, use the appName as provided
            string realProcessName = entry.Key ?? appName;

            var cleanName = realProcessName.Replace(".exe", "", StringComparison.OrdinalIgnoreCase).Trim();

            // 2. Try to find the running process
            var process = Process.GetProcessesByName(cleanName).FirstOrDefault();
            if (process != null)
            {
                try { return process.MainModule.FileName; }
                catch { /* Access denied to MainModule */ }
            }

            // 3. Fallbacks (Hardcoded paths)
            var lowerName = appName.ToLower();
            if (lowerName.Contains("calculator")) return @"C:\Windows\System32\calc.exe";
            if (lowerName.Contains("explorer")) return @"C:\Windows\explorer.exe";
            if (lowerName.Contains("chrome")) return @"C:\Program Files\Google\Chrome\Application\chrome.exe";

            // Specific Fix for Visual Studio (devenv)
            if (lowerName.Contains("visual studio"))
                return @"C:\Program Files\Microsoft Visual Studio\2022\Community\Common7\IDE\devenv.exe";

            // Specific Fix for Notepad++
            if (lowerName.Contains("notepad++"))
                return @"C:\Program Files\Notepad++\notepad++.exe";

            return string.Empty;
        }
        catch
        {
            return string.Empty;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            localStorageModule = await JSRuntime.InvokeAsync<IJSObjectReference>("import", "./js/localStorage.js");

            // ONLY use App.first logic if permissions haven't been set yet
            // LoadUserTrackingPermissions() should have already set the correct isOn state
            if (App.first)
            {
                // Check if we already set isOn based on permissions
                if (isManualTrackingAllowed == null && isAutoTrackingAllowed == null)
                {
                    // Permissions not loaded yet, use default
                    Console.WriteLine("App.first is true and permissions not loaded - setting isOn = false");
                    isOn = false;
                    await localStorageModule.InvokeVoidAsync("setIsOnState", isOn);
                    StopAll();
                }
                else
                {
                    Console.WriteLine($"\n========== OnAfterRenderAsync - App.first = true ==========");
                    Console.WriteLine($"Permissions loaded: isManualTrackingAllowed={isManualTrackingAllowed}, isAutoTrackingAllowed={isAutoTrackingAllowed}");
                    Console.WriteLine($"Current isOn state (from LoadUserTrackingPermissions): {isOn}");

                    // Initialize localStorage with the permission-based state
                    await localStorageModule.InvokeVoidAsync("setIsOnState", isOn);
                    Console.WriteLine($"Synced localStorage with isOn={isOn}");

                    Preferences.Set("IsOnState", isOn);
                    Console.WriteLine($"Synced Preferences with isOn={isOn}");

                    // Start appropriate tracking based on permissions
                    if (isManualTrackingAllowed == true && isAutoTrackingAllowed != true)
                    {
                        // Case 1: Manual only - start manual tracking (isOn should be true)
                        if (isOn)
                        {
                            Console.WriteLine("Case 1: Starting MANUAL tracking");
                            StopAll();
                            StartAll("manual");
                        }
                    }
                    else if (isManualTrackingAllowed != true && isAutoTrackingAllowed == true)
                    {
                        // Case 2: Auto only - start automatic tracking
                        Console.WriteLine("Case 2: Starting AUTOMATIC tracking");
                        StopAll();
                        StartAll("automatic");
                    }
                    else if (isManualTrackingAllowed == true && isAutoTrackingAllowed == true)
                    {
                        // Case 3: Both allowed - start based on isOn state
                        Console.WriteLine($"Case 3: Checking isOn state - isOn={isOn}");
                        if (isOn)
                        {
                            Console.WriteLine("Case 3: isOn=true - Switching to MANUAL tracking mode");
                            StopAll();
                            StartAll("manual");
                        }
                        else
                        {
                            Console.WriteLine("Case 3: isOn=false - Switching to AUTOMATIC tracking mode");
                            StopAll();
                            StartAll("automatic");
                        }
                    }
                    else
                    {
                        // Case 4: No permissions - stop all
                        Console.WriteLine("Case 4: Stopping all tracking");
                        StopAll();
                    }
                    Console.WriteLine("===========================================================\n");
                }
                App.first = false;
            }
            else
            {
                // For subsequent renders (when navigating back to page), preserve the tracking state
                // DO NOT restart tracking here - let the existing tracking continue
                // Only update the isOn state from localStorage for UI display

                if (isManualTrackingAllowed == true && isAutoTrackingAllowed == true)
                {
                    // Case 3: Both allowed - read from Preferences (more reliable than localStorage for MAUI)
                    isOn = Preferences.Get("IsOnState", false); // Default to false (automatic) for fresh login
                    Console.WriteLine($"Case 3: Restoring state from Preferences - isOn={isOn}");

                    // Also sync to localStorage for web compatibility
                    await localStorageModule.InvokeVoidAsync("setIsOnState", isOn);
                }
                else if (isManualTrackingAllowed == true && isAutoTrackingAllowed != true)
                {
                    // Case 1: Manual only - read from Preferences
                    isOn = Preferences.Get("IsOnState", true); // Default to true if not set
                    Console.WriteLine($"Case 1: Restoring state from Preferences - isOn={isOn}");

                    // Also sync to localStorage
                    await localStorageModule.InvokeVoidAsync("setIsOnState", isOn);

                    // Only start/stop tracking if this is truly a fresh start (not just page navigation)
                    // Check if tracking services are already running
                    if (isOn)
                    {
                        // User wants manual tracking ON
                        Console.WriteLine("Case 1: Ensuring manual tracking is running");
                        // Don't call StopAll/StartAll here as it will interrupt existing tracking
                        // Only start if not already running (first time after login)
                        if (App.first)
                        {
                            StartAll("manual");
                        }
                    }
                    else
                    {
                        // User wants tracking OFF
                        Console.WriteLine("Case 1: Ensuring tracking is stopped");
                        if (App.first)
                        {
                            StopAll();
                        }
                    }
                }
                else if (isManualTrackingAllowed != true && isAutoTrackingAllowed == true)
                {
                    // Case 2: Auto only - force OFF (button hidden, auto tracking runs)
                    isOn = false;
                    Console.WriteLine("Case 2: Auto tracking only - button hidden (tracking continues in background)");
                }
                else
                {
                    // Case 4: No permissions - OFF
                    isOn = false;
                    Console.WriteLine("Case 4: No permissions - button hidden");
                }
                StateHasChanged();
            }

            if (userId > 0)
            {
                // UpdateChart() calls LoadDataAsync, which sets chartDataReady = true
                await UpdateChart();
            }
        }

        var dotNetRef = DotNetObjectReference.Create(this);

        // Select2 Initialization (Existing Logic)
        if (admins != null && admins.Any() && !isSelect2AdminInitialized)
        {
            try
            {
                await JSRuntime.InvokeVoidAsync("initializeSelect2", "admin-select", dotNetRef);
                isSelect2AdminInitialized = true;
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Error initializing Admin Select2: {ex.Message}");
            }
        }

        if (users != null && users.Any() && !isSelect2UserInitialized && userRole?.ToLower() == "superadmin")
        {
            try
            {
                // await Task.Delay(50);
                await JSRuntime.InvokeVoidAsync("initializeSelect2", "user-select", dotNetRef);
                isSelect2UserInitialized = true;
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Error initializing User Select2: {ex.Message}");
            }
        }

        if (users != null && users.Any() && !isSelect2UserInitialized && userRole?.ToLower() == "admin")
        {
            try
            {
                // await Task.Delay(50);
                await JSRuntime.InvokeVoidAsync("initializeSelect2", "user-select-admin", dotNetRef);
                isSelect2UserInitialized = true;
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Error initializing User Select2: {ex.Message}");
            }
        }

        // Fix: Only run Select2 initialization if the Usage Type dropdown is visible (userId > 0)
        // and has not been initialized yet.
        if (userId > 0 && !isSelect2UsageTypeInitialized)
        {
            try
            {
                // Adding a small delay helps ensure the DOM element is fully ready.
                // await Task.Delay(50);
                await JSRuntime.InvokeVoidAsync("initializeSelect2", "usage-type-select", dotNetRef);
                isSelect2UsageTypeInitialized = true;
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Error initializing Usage Type Select2: {ex.Message}");
            }
        }

        // 🎯 CHART RENDERING FIX: This is the critical block that was missing
        // to fix the chart timing issue on data loads.
        if (chartDataReady && labels.Any())
        {
            // Reset the flag immediately to prevent repeated calls
