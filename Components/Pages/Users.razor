 @page "/users"
@layout MainLayout
@inject UserService UserService
@inject IJSRuntime JSRuntime
@using ScreenTracker1.Models
@using ScreenTracker1.Services
@using System.Text.Json
@using ScreenTracker1.DTOS
@using Microsoft.JSInterop;
@using System.IdentityModel.Tokens.Jwt;
@using ScreenTracker1.Components.Layout
@inject NavigationManager NavigationManager
@inject DesktopAutoCaptureService desktopAutoCaptureService
@inject AfkTrackerService afkTrackerService
@inject SystemThemeService SystemThemeService
@inject AppUsageTracker appUsageTrackerService
@inject UserSelectionStateService UserStateService
@using NEvaldas.Blazor.Select2
@* <NavMenu OnLogoutTriggered="PerformLogout" />
@layout ScreenTracker1.Components.Layout.NoNavLayout *@

<div class="p-4" style="min-height: 100vh;">
    @if (isAdmin)
    {
        @if (users == null && admins == null && (userRole?.ToLower() == "admin" || userRole?.ToLower() == "superadmin"))
        {
            <p><em>Loading admin/user lists...</em></p>
        }
        else
        {
            <div class="selectbox">
                @if (userRole?.ToLower() == "superadmin")
                {
                    <div class="toolbar-section">
                        <label class="label">Select Admin</label>
                        <div class="tooltip-container">
                            <select id="admin-select" @onchange="OnSelectedAdminChanged" class="stitch-user-select" value="@selectedAdminUsername">
                                <option value="">Select Admin</option>
                                @foreach (var admin in admins)
                                {
                                    <option value="@admin.username">@admin.username</option>
                                }
                            </select>
                            @*  <span class="tooltip-text tooltip-bottom">Choose an admin from the list</span> *@
                        </div>
                    </div>

                    @if (users != null && users.Count > 0)
                    {
                        <div class="toolbar-section toolbar-section-select-user">
                            <label class="label">Select User</label>
                            <div class="tooltip-container">
                                <select id="user-select" @onchange="OnSelectedUserChanged" class="stitch-user-select ms-2" value="@selectedUsername">
                                    <option value="">Select User</option>
                                    @foreach (var user in users)
                                    {
                                        <option value="@user.username">@user.username</option>
                                    }
                                </select>
                                <span class="tooltip-text tooltip-bottom">Choose a user from the list</span>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <div class="toolbar-section">
                        <label class="label">Select User</label>
                        <div class="tooltip-container">
                            <select id="user-select-admin" @onchange="OnSelectedUserChanged" class="stitch-user-select" value="@selectedUsername">
                                <option value="">Select a user</option>
                                @foreach (var user in users)
                                {
                                    <option value="@user.username">@user.username</option>
                                }
                            </select>
                            <span class="tooltip-text tooltip-bottom">Choose a user from the list</span>
                        </div>
                    </div>
                }

                @if (userId > 0)
                {
                    <div class="toolbar-section">
                        <label class="label label-usage-type">Usage Type</label>
                        <div class="tooltip-container">
                            <select id="usage-type-select" @onchange="OnUsageTypeChanged" class="stitch-user-select ms-2" value="@selectedUsageType">
                                <option value="all">All</option>
                                <option value="manual">Manual</option>
                                <option value="automatic">Automatic</option>
                            </select>
                            <span class="tooltip-text tooltip-bottom">Filter data by usage type</span>
                        </div>
                    </div>
                }
            </div>
        }
    }

    @if (userId != null && userId > 0)
    {
        <div class="stitch-container">
            <div class="toolbar-container grid-toolbar">

                <div class="toolbar-left toolbar-AutoRefresh">
                    <div class="tooltip-container mr-4">
                        <input type="date"
                               @onchange="OnDateChanged"
                               value="@selectedDate.ToString("yyyy-MM-dd")"
                               max="@maxSelectableDate"
                               class="stitch-date-picker" />
                        <span class="tooltip-text">Select a Date</span>
                    </div>

                    <div class="tooltip-container-Auto-Refresh">
                        <label class="label mr-2 label-Auto-Refresh">Auto Refresh</label>
                        <select class="stitch-dropdown" @onchange="OnIntervalChanged" value="@selectedInterval">
                            <option value="0">Off</option>
                            <option value="10">10s</option>
                            <option value="20">20s</option>
                            <option value="30">30s</option>
                        </select>
                        <span class="tooltip-text tooltip-text-Auto-Refresh">Interval to refresh</span>
                    </div>
                </div>

                <div class="toolbar-center">
                    <div class="toolbar-section toolbar-section-tracker">
                        <label class="label">Tracking Status</label>
                        <div class="tooltip-container">
                            <button class="tracking-toggle @(isOn ? "tracking-on" : "tracking-off")"
                                    @onclick="OnToggleStateClicked"
                                    aria-label="Toggle tracking state">
                                @if (isOn)
                                {
                                    <span class="tracking-indicator tracking-active"></span>
                                    <span class="tracking-text">ON</span>
                                }
                                else
                                {
                                    <span class="tracking-indicator"></span>
                                    <span class="tracking-text">OFF</span>
                                }
                            </button>
                            <span class="tooltip-text">Toggle tracking state</span>
                        </div>
                    </div>
                </div>

                <div class="toolbar-right">
                    <div class="btn-group" role="group" aria-label="Toolbar Actions">
                        <div class="tooltip-container mr-2">
                            <button class="stitch-refresh-btn btn btn-primary" style="background-color:#912bb9; border-radius: 8px;" @onclick="OnRefreshClicked">
                                <i class="fas fa-sync-alt me-2"></i> Refresh
                            </button>
                            <span class="tooltip-text">Refresh page</span>
                        </div>
                        <div class="tooltip-container">
                            <button class="stitch-refresh-btn btn btn-primary" style="background-color:#592cab; border-radius: 8px;" @onclick="OnViewScreenshotsClicked">
                                <i class="bi bi-camera"></i> Screen
                            </button>
                            <span class="tooltip-text">Screenshots</span>
                        </div>
                    </div>
                </div>
            </div>





            <div class="chart-container">
                @if (isChartLoading)
                {
                    <div class="card p-3 rounded-3 shadow-sm placeholder-glow" style="min-height:350px; width:100%">
                        <h4 class="card-title"><span class="placeholder col-8"></span></h4>
                        <p class="card-text"><span class="placeholder col-12"></span></p>
                        <p class="card-text"><span class="placeholder col-10"></span></p>
                        <div style="height:200px">
                            <span class="placeholder col-12 h-100"></span>
                        </div>
                    </div>
                }
                else
                {
                    <canvas id="barChart" class="stitch-chart"></canvas>

                }
                <div class="dashboard-grid-container">

                    <div class="login-card-item">
                        <div class="dashboard-card login-card h-100">
                            <div class="card-header">
                                <span class="card-icon"><i class="fas fa-sign-in-alt"></i></span>
                                <span class="card-title">Login At</span>
                                <span class="card-options">...</span>
                            </div>
                            <div class="card-body">
                                <div class="main-value">@LoginTime</div>
                                <div class="sub-text">Time of Day</div>
                            </div>
                        </div>
                    </div>

                    <div class="stats-grid-container">
                        @if (isAfkDataLoading)
                        {
                            <div class="stat-card-item">
                                <div class="dashboard-card">
                                </div>
                            </div>
                            <div class="stat-card-item">
                                <div class="dashboard-card">
                                </div>
                            </div>
                            <div class="stat-card-item">
                                <div class="dashboard-card">
                                </div>
                            </div>
                            <div class="stat-card-item">
                                <div class="dashboard-card">
                                </div>
                            </div>
                        }
                        else
                        {
                            <div class="stat-card-item">
                                <div class="dashboard-card dashboard-card-voilet">
                                    <div class="card-header">
                                        <span class="card-icon"><i class="fas fa-hourglass-half"></i></span>
                                        <span class="card-title">Ideal Time</span>
                                        <span class="card-options">...</span>
                                    </div>
                                    <div class="card-body">
                                        <div class="main-value">@FormatDuration(totalAfkMinutes)</div>
                                        <div class="sub-text">Time Away from Keyboard</div>
                                    </div>
                                </div>
                            </div>

                            <div class="stat-card-item">
                                <div class="dashboard-card active-card dashboard-card-pink-voilet">
                                    <div class="card-header">
                                        <span class="card-icon"><i class="fas fa-running"></i></span>
                                        <span class="card-title">Active Time</span>
                                        <span class="card-options">...</span>
                                    </div>
                                    <div class="card-body">
                                        <div class="main-value">@FormatDuration(totalTimeInMinutes - totalAfkMinutes)</div>
                                        <div class="sub-text">Time On Task</div>
                                    </div>
                                </div>
                            </div>

                            <div class="stat-card-item">
                                <div class="dashboard-card dashboard-card-voilet">
                                    <div class="card-header">
                                        <span class="card-icon"><i class="fas fa-clock"></i></span>
                                        <span class="card-title">Total Time</span>
                                        <span class="card-options">...</span>
                                    </div>
                                    <div class="card-body">
                                        <div class="main-value">@FormatDuration(totalTimeInMinutes)</div>
                                        <div class="sub-text">Total Shift Duration</div>
                                    </div>
                                </div>
                            </div>

                            <div class="stat-card-item">
                                <div class="dashboard-card dashboard-card-pink-voilet">
                                    <div class="card-header">
                                        <span class="card-icon"><i class="fas fa-sign-in-alt"></i></span>
                                        <span class="card-title">Check-in Time</span>
                                        <span class="card-options">...</span>
                                    </div>
                                    <div class="card-body">
                                        @if (string.IsNullOrEmpty(CheckinTime))
                                        {
                                            <div class="main-value">0h 0m 0s</div>
                                        }
                                        else
                                        {
                                            <div class="main-value">@CheckinTime</div>
                                        }
                                        <div class="sub-text">Time of Day</div>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>

            <div class="stitch-tabs">
                <div class="stitch-tab @(selectedTab == "summary" ? "active" : "")" @onclick='() => SelectTab("summary")'>Summary</div>
                <div class="stitch-tab @(selectedTab == "window" ? "active" : "")" @onclick='() => SelectTab("window")'>Window</div>
            </div>

            <div class="stitch-tab-content">
                @if (selectedTab == "summary")
                {
                    <div class="stitch-summary-grid">
                        <section class="stitch-card">
                            <h4>Top Applications</h4>
                            @if (isAppUsageLoading)
                            {
                                <div class="card p-3 placeholder-glow">
                                    <h4 class="placeholder-glow"><span class="placeholder col-8"></span></h4>
                                    <div class="placeholder-glow my-2"><span class="placeholder col-10"></span></div>
                                    <div class="placeholder-glow my-2"><span class="placeholder col-12"></span></div>
                                    <div class="placeholder-glow my-2"><span class="placeholder col-9"></span></div>
                                </div>
                            }
                            else if (appUsageList != null && appUsageList.Any())
                            {
                                var totalAppTime = appUsageList.Sum(a => a.durationInMinutes);
                                foreach (var app in appUsageList)
                                {
                                    var percent = (app.durationInMinutes / totalAppTime) * 100;
                                    <div class="stitch-bar" @onclick="() => OnAppClick(app.appName)">
                                        <div style="width:@percent%;background-color:@GetDynamicColor(app.appName);height:100%;"></div>
                                        <div class="progress-bar-fill" style="width:@percent%;background-color:@GetDynamicColor(app.appName);"></div>

                                        @* NEW: Use bar-content wrapper for better icon alignment *@
                                        <div class="bar-content">
                                            <span class="label app-label-content">
                                                @* NEW: Icon display using the helper method *@
                                                <i class="@GetAppIconClass(app.appName) app-icon"></i>
                                                @app.appName
                                            </span>
                                            <span class="time">@FormatDuration(app.durationInMinutes)</span>
                                        </div>
                                    </div>
                                }
                                <div class="stitch-button-row">
                                    @if (moreAppUsageAvailable)
                                    {
                                        <button class="stitch-btn" @onclick="LoadMoreAppUsage">
                                     @*          <i class="fas fa-plus"></i> Show More *@
                                     @*         <i class="fas fa-arrow-down"></i> Show More
                                            <i class="fas fa-chevron-down"></i> Show More *@
                                            <i class="fas fa-plus-circle"></i> Show More
                                                @*   <i class="fas fa-expand"></i> Show More *@
                                        </button>
                                    }
                                    @if (currentAppUsagePage > 1)
                                    {
                                        <button class="stitch-btn" @onclick="ShowLessAppUsage">
                                      @*         <i class="fas fa-minus"></i> Show Less *@
                                       @*       <i class="fas fa-arrow-up"></i> Show Less *@
                                            @*   <i class="fas fa-arrow-up"></i> Show Less *@
                                            <i class="fas fa-minus-circle"></i> Show Less
                                        </button>
                                    }
                                </div>

                            }
                            else
                            {
                                <p>No applications to display.</p>
                            }
                        </section>

                        @if (!string.IsNullOrEmpty(selectedAppName))
                        {
                            <section class="stitch-card">
                                <h4>Top Window Titles "@selectedAppName"</h4>
                                @if (appTitleList != null && appTitleList.Any())
                                {
                                    var totalTitleTime = appTitleList.Sum(t => t.durationInMinutes);
                                    <div class="title-list-container">
                                        @foreach (var title in appTitleList)
                                        {
                                            var percent = (title.durationInMinutes / totalTitleTime) * 100;
                                            <div class="stitch-bar">
                                                <div style="width:@percent%;background-color:@GetDynamicColor(title.title);height:100%;"></div>
                                                <span class="label" data-tooltip="@title.title">@title.title</span>
                                                <span class="time">@FormatDuration(title.durationInMinutes)</span>
                                            </div>
                                        }
                                    </div>
                                    <div class="stitch-button-row">
                                        @if (appTitleList.Count >= titlePageSize && moreTitlesAvailable)
                                        {
                                            <button class="stitch-btn" @onclick="LoadMoreTitles">
                                                <i class="fas fa-plus-circle"></i>
                                                Show More
                                            </button>
                                          
                                        }
                                        @if (currentTitlePage > 1)
                                        {
                                            <button class="stitch-btn" @onclick="ShowLessTitles"> <i class="fas fa-minus-circle"></i> Show Less</button>
                                        }
                                    </div>
                                }
                                else
                                {
                                    <p>No window titles available for this date.</p>
                                }
                            </section>

                            <section class="stitch-card">
                                <h4>Top Categories for "@selectedAppName"</h4>
                                @if (categoryKeywordGroups != null && categoryKeywordGroups.Any())
                                {
                                    var totalCategoryTime = categoryKeywordGroups.Sum(c => c.totalDurationInMinutes);
                                    foreach (var category in categoryKeywordGroups)
                                    {
                                        var percent = (category.totalDurationInMinutes / totalCategoryTime) * 100;
                                        <div class="stitch-bar">
                                            <div style="width:@percent%;background-color:@GetDynamicColor(category.category);height:100%;"></div>
                                            <span class="label">@category.category</span>
                                        </div>
                                    }
                                    <div class="stitch-button-row">
                                        @if (categoryKeywordGroups.Count >= 5 || categoryKeywordGroups.Count < totalCategoryRecords)
                                        {
                                            <button class="stitch-btn" @onclick="LoadMoreCategories">Show More</button>
                                        }
                                        @if (currentCategoryPage > 1)
                                        {
                                            <button class="stitch-btn" @onclick="ShowLessCategories">Show Less</button>
                                        }
                                    </div>
                                }
                                else
                                {
                                    <p>No category data available for this date.</p>
                                }
                            </section>
                        }
                    </div>
                }
         
            </div>
        </div>
    }
</div>

@code {
    private List<User> users;
    private string selectedUsername;
    private User selectedUser;
    private List<AppUsage> appUsageList;
    private List<AppTitle> appTitleList;
    private string selectedTab = "summary";
    private DateTime selectedDate = DateTime.Today;
    private List<string> labels = new();
    private List<double> data = new();
    private List<CategoryKeywordGroup> categoryKeywordGroups;
    private int currentTitlePage = 1;
    private const int titlePageSize = 5;
    private bool moreTitlesAvailable = true;
    private List<AppTitle> initialAppTitleList = new();
    private int currentAppUsagePage = 1;
    private const int appUsagePageSize = 5;
    private bool moreAppUsageAvailable = true;
    private List<AppUsage> initialAppUsageList = new();

    private int currentCategoryPage = 1;
    private const int categoryPageSize = 5;
    private bool moreCategoriesAvailable = true;
    private List<CategoryKeywordGroup> initialCategoryList = new();
    private string token;
    private bool isAdmin;

    private int currentPage = 1;
    private int totalPages = 1;
    private const int itemsPerPage = 5;
    private List<AppUsage> appUsageListuser = new List<AppUsage>();
    private string UserName;

    private int userId;
    // private double totalTimeInMinutes => appUsageList?.Sum(a => a.durationInMinutes) ?? 0;
    private double totalTimeInMinutes;



    private int totalAppUsageRecords;
    private int totalAppTitleRecords;
    private int totalCategoryRecords;

    private int selectedInterval = 0;
    private System.Timers.Timer? _refreshTimer;

    private string selectedAppName;
    private const int takePerPage = 5;
    private string? LoginTime;
    private string? CheckinTime;

    private List<Screenshots> screenshots = new();
    private bool showScreenshots = false;

    private bool isOn = false;

    private double totalAfkMinutes;


    private string ToggleIconWithText => isOn
    ? "<i class='fa-solid fa-power-off'></i> ON"
    : "<i class='fa-solid fa-ban'></i> OFF";


    private bool CanShowMoreAppUsage => moreAppUsageAvailable && appUsageList.Count < totalAppUsageRecords;
    private bool CanShowMoreTitles => moreTitlesAvailable && appTitleList.Count < totalAppTitleRecords;
    private string maxSelectableDate = DateTime.Today.ToString("yyyy-MM-dd");

    private IJSObjectReference? localStorageModule;

    private bool showMenu = false;


    private List<User> admins;


    private string selectedAdminUsername;
    private User selectedAdmin;
    private string userRole;
    private int loggedInUserId;

    private string selectedUsageType = "all";
    private bool isSelect2AdminInitialized = false;
    private bool isSelect2UserInitialized = false;
    private bool isSelect2UsageTypeInitialized = false;

    private bool isChartLoading = true;
    private bool isAppUsageLoading = true;
    private bool isAfkDataLoading = true;

    // private List<string> labels = new List<string>();
    private List<double> totalData = new List<double>();
    private List<double> afkData = new List<double>();
    private List<double> activeData = new List<double>();
    private bool chartDataReady = false;

    [JSInvokable]
    public async Task OnSelect2Changed(string elementId, string value)
    {
        if (elementId == "admin-select")
        {
            selectedAdminUsername = value;
            UserStateService.SelectedAdminUsername = selectedAdminUsername;
            selectedAdmin = admins.FirstOrDefault(a => a.username == selectedAdminUsername);
            users = new List<User>();
            selectedUsername = null;
            selectedUser = null;
            userId = 0;
            appUsageList = null;
            appTitleList = null;
            isSelect2UserInitialized = false;
            UserStateService.Users = users;
            UserStateService.SelectedUsername = null;
            UserStateService.UserId = 0;

            // 👇 FIX: Reset Usage Type Select2 flag when admin changes and user dropdown is cleared
            isSelect2UsageTypeInitialized = false;

            if (selectedAdmin != null)
            {
                users = await UserService.GetAllUsersByAdminAsync(selectedAdmin.id, "admin");
                UserStateService.Users = users;
            }
        }
        else if (elementId == "user-select" || elementId == "user-select-admin")
        {
            UserStateService.SelectedUsername = value;
            selectedUsername = UserStateService.SelectedUsername;
            selectedUser = users.FirstOrDefault(u => u.username == selectedUsername);

            if (selectedUser != null)
            {
                App.SelectedUserId = selectedUser.id;
                userId = selectedUser.id;
                UserStateService.UserId = userId;
                LoginTime = await UserService.GetUserLoginTimeFormattedAsync(userId);

                // No need to reset the flag here, as it will be initialized in OnAfterRenderAsync
                // if it hasn't been already.

                await Task.WhenAll(
                    LoadDataAsync(userId),
                    LoadAppUsageData(),
                    LoadAfkDataAsync(userId),
                    LoadCheckinTime(userId)

                );
                      
                await UpdateChart();
            }
            else
            {
                App.SelectedUserId = 0;
                userId = 0;
                UserStateService.UserId = 0;
                appUsageList = null;
                appTitleList = null;
                UserStateService.SelectedUsername = null;

                // 👇 FIX: Reset Usage Type Select2 flag when user selection is cleared (dropdown is hidden)
                isSelect2UsageTypeInitialized = false;
            }
        }
        else if (elementId == "usage-type-select")
        {
            selectedUsageType = value;
            UserStateService.SelectedUsageType = selectedUsageType;

            selectedAppName = null;

            await LoadDataAsync(userId);

            await LoadAppUsageData();
            await LoadAfkDataAsync(userId);
            await UpdateChart();
            await LoadCheckinTime(userId);
        }
        StateHasChanged();
    }

    private string GetAppIconClass(string appName)
    {
        // Use a simple mapping, case-insensitive, on common process/app names
        var normalizedName = appName.ToLowerInvariant();

        if (normalizedName.Contains("chrome")) return "fab fa-chrome";
        if (normalizedName.Contains("edge")) return "fab fa-edge";
        if (normalizedName.Contains("firefox")) return "fab fa-firefox";
        if (normalizedName.Contains("teams")) return "fas fa-users";
        if (normalizedName.Contains("outlook")) return "fas fa-envelope-open-text";
        if (normalizedName.Contains("word") || normalizedName.Contains("excel") || normalizedName.Contains("powerpoint")) return "fab fa-microsoft";
        if (normalizedName.Contains("visual studio")) return "fas fa-code";
        if (normalizedName.Contains("code") || normalizedName.Contains("vscode")) return "fas fa-terminal";
        if (normalizedName.Contains("slack")) return "fab fa-slack";
        if (normalizedName.Contains("zoom")) return "fas fa-video";
        if (normalizedName.Contains("reader") || normalizedName.Contains("pdf")) return "fas fa-file-pdf";
        if (normalizedName.Contains("spotify") || normalizedName.Contains("music")) return "fab fa-spotify";
        if (normalizedName.Contains("settings")) return "fas fa-cogs";
        if (normalizedName.Contains("file explorer") || normalizedName.Contains("explorer")) return "fas fa-folder-open";
        if (normalizedName.Contains("snipping tool") || normalizedName.Contains("snip")) return "fas fa-cut";
        if (normalizedName.Contains("anydesk")) return "fas fa-link";
        if (normalizedName.Contains("photos")) return "fas fa-image";
        if (normalizedName.Contains("ultraviewer")) return "fas fa-satellite-dish";
        if (normalizedName.Contains("notepad")) return "fas fa-file-alt";

        return "fas fa-desktop";
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            localStorageModule = await JSRuntime.InvokeAsync<IJSObjectReference>("import", "./js/localStorage.js");
            if (App.first)
            {
                isOn = false;
                await localStorageModule.InvokeVoidAsync("setIsOnState", isOn);
                StopAll();
                App.first = false;
            }
            else
            {
                isOn = await localStorageModule.InvokeAsync<bool>("getIsOnState");
                StateHasChanged();
            }

            if (userId > 0)
            {
                // UpdateChart() calls LoadDataAsync, which sets chartDataReady = true
                await UpdateChart();
            }
        }

        var dotNetRef = DotNetObjectReference.Create(this);

        // Select2 Initialization (Existing Logic)
        if (admins != null && admins.Any() && !isSelect2AdminInitialized)
        {
            try
            {
                await JSRuntime.InvokeVoidAsync("initializeSelect2", "admin-select", dotNetRef);
                isSelect2AdminInitialized = true;
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Error initializing Admin Select2: {ex.Message}");
            }
        }

        if (users != null && users.Any() && !isSelect2UserInitialized && userRole?.ToLower() == "superadmin")
        {
            try
            {
                // await Task.Delay(50);
                await JSRuntime.InvokeVoidAsync("initializeSelect2", "user-select", dotNetRef);
                isSelect2UserInitialized = true;
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Error initializing User Select2: {ex.Message}");
            }
        }

        if (users != null && users.Any() && !isSelect2UserInitialized && userRole?.ToLower() == "admin")
        {
            try
            {
                // await Task.Delay(50);
                await JSRuntime.InvokeVoidAsync("initializeSelect2", "user-select-admin", dotNetRef);
                isSelect2UserInitialized = true;
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Error initializing User Select2: {ex.Message}");
            }
        }

        // Fix: Only run Select2 initialization if the Usage Type dropdown is visible (userId > 0)
        // and has not been initialized yet.
        if (userId > 0 && !isSelect2UsageTypeInitialized)
        {
            try
            {
                // Adding a small delay helps ensure the DOM element is fully ready.
                // await Task.Delay(50);
                await JSRuntime.InvokeVoidAsync("initializeSelect2", "usage-type-select", dotNetRef);
                isSelect2UsageTypeInitialized = true;
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Error initializing Usage Type Select2: {ex.Message}");
            }
        }

        // 🎯 CHART RENDERING FIX: This is the critical block that was missing
        // to fix the chart timing issue on data loads.
        if (chartDataReady && labels.Any())
        {
            // Reset the flag immediately to prevent repeated calls
            chartDataReady = false;

            try
            {
                // Call the NEW JavaScript function name with all four lists
                await JSRuntime.InvokeVoidAsync("renderGroupedBarChart",
                                                labels,
                                                totalData,
                                                afkData,
                                                activeData);
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Error rendering chart: {ex.Message}");
            }
        }
    }
