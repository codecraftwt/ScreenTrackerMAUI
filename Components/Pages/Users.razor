    private async Task OnToggleStateClicked()
    {
        // SuperAdmin should NOT have any tracking (neither manual nor automatic)
        if (userRole?.ToLower() == "superadmin")
        {
            Console.WriteLine("SuperAdmin cannot use tracking - SuperAdmin only views tracked admins and users");
            return;
        }

        // Case 1: ONLY manual tracking allowed - Allow toggle ON/OFF
        if (isManualTrackingAllowed == true && isAutoTrackingAllowed != true)
        {
            isOn = !isOn;
            await localStorageModule.InvokeVoidAsync("setIsOnState", isOn);
            Preferences.Set("IsOnState", isOn);

            if (isOn)
            {
                // Turn ON manual tracking - Create NEW manual entry
                Console.WriteLine("Case 1: Starting manual tracking (ON) - Creating new manual entry");
                StopAll();
                StartAll("manual");
            }
            else
            {
                // Turn OFF tracking - End current manual entry (set IsActive = false)
                Console.WriteLine("Case 1: Stopping manual tracking (OFF) - Ending current manual entry");
                StopAll();
                await UserService.EndDailyTrackerAsync();
            }
            StateHasChanged();
            return;
        }

        // Case 2: ONLY auto tracking allowed - Should not reach here (button hidden)
        if (isManualTrackingAllowed != true && isAutoTrackingAllowed == true)
        {
            Console.WriteLine("Case 2: Toggle clicked but button should be hidden for auto-only mode");
            return;
        }

        // Case 3: BOTH permissions granted - Allow toggle between manual and automatic
        if (isManualTrackingAllowed == true && isAutoTrackingAllowed == true)
        {
            bool oldState = isOn;
            isOn = !isOn;
            Console.WriteLine($"Case 3: Toggle clicked - Changing isOn from {oldState} to {isOn}");

            await localStorageModule.InvokeVoidAsync("setIsOnState", isOn);
            Preferences.Set("IsOnState", isOn);

            // Verify it was saved
            bool savedValue = Preferences.Get("IsOnState", false);
            Console.WriteLine($"Case 3: Verified Preferences saved value = {savedValue}");

            if (isOn)
            {
                // Switching to manual tracking
                Console.WriteLine("Case 3: Switching to manual tracking mode");
                StopAll();
                StartAll("manual");
            }
            else
            {
                // Switching to automatic tracking
                Console.WriteLine("Case 3: Switching to automatic tracking mode");
                StopAll();
                StartAll("automatic");
            }
            StateHasChanged();
            return;
        }

        // Case 4: No permissions - Should not reach here (button hidden)
        Console.WriteLine("Case 4: Toggle clicked but no permissions granted");
    }

    private bool IsTrackingButtonDisabled()
    {
        // SuperAdmin: button disabled (they don't track)
        if (userRole?.ToLower() == "superadmin")
            return true;

        // Case 1: ONLY manual tracking allowed → ENABLED (can toggle ON/OFF)
        if (isManualTrackingAllowed == true && isAutoTrackingAllowed != true)
            return false;

        // Case 2: ONLY auto tracking allowed → Button should be hidden, not shown
        if (isManualTrackingAllowed != true && isAutoTrackingAllowed == true)
            return true;

        // Case 3: BOTH allowed → ENABLED (can toggle between manual and automatic)
        if (isManualTrackingAllowed == true && isAutoTrackingAllowed == true)
            return false;

        // Case 4: NO permissions → DISABLED (button shouldn't even be visible)
        return true;
    }

    private bool ShouldShowTrackingButton()
    {
        Console.WriteLine($"ShouldShowTrackingButton called - userRole: {userRole}, userId: {userId}, loggedInUserId: {loggedInUserId}");
        Console.WriteLine($"isManualTrackingAllowed: {isManualTrackingAllowed}, isAutoTrackingAllowed: {isAutoTrackingAllowed}");

        // Don't show for SuperAdmin
        if (userRole?.ToLower() == "superadmin")
        {
            Console.WriteLine("Returning false: User is SuperAdmin");
            return false;
        }

        // Don't show when viewing other users (when admin selects from dropdown)
        // Only show when viewing own account (userId == loggedInUserId)
        if (userId == 0 || userId != loggedInUserId)
        {
            Console.WriteLine($"Returning false: userId ({userId}) is 0 or not equal to loggedInUserId ({loggedInUserId})");
            return false;
        }

        // Case 1: Only manual tracking allowed - Show button (can toggle ON/OFF)
        if (isManualTrackingAllowed == true && isAutoTrackingAllowed != true)
        {
            Console.WriteLine("Returning true: Case 1 - Manual tracking only (toggleable ON/OFF)");
            return true;
        }

        // Case 2: Only auto tracking allowed - Hide button (automatic only)
        if (isManualTrackingAllowed != true && isAutoTrackingAllowed == true)
        {
            Console.WriteLine("Returning false: Case 2 - Auto tracking only (button hidden)");
            return false;
        }

        // Case 3: Both manual and auto tracking allowed - Show button (toggleable)
        if (isManualTrackingAllowed == true && isAutoTrackingAllowed == true)
        {
            Console.WriteLine("Returning true: Case 3 - Both tracking modes allowed");
            return true;
        }

        // Case 4: No tracking permissions - Don't show button
        Console.WriteLine("Returning false: Case 4 - No tracking permissions");
        return false;
    }

    private string GetTrackingTooltip()
    {
        if (userRole?.ToLower() == "superadmin")
            return "SuperAdmin cannot use tracking";

        // Case 1: When viewing own account with ONLY manual tracking permission
        if (isManualTrackingAllowed == true && isAutoTrackingAllowed != true)
            return isOn ? "Click to stop tracking" : "Click to start manual tracking";

        // Case 2: When viewing own account with ONLY auto tracking permission
        if (isManualTrackingAllowed != true && isAutoTrackingAllowed == true)
            return "Automatic tracking is running";

        // Case 3: When BOTH permissions allowed
        if (isManualTrackingAllowed == true && isAutoTrackingAllowed == true)
            return isOn ? "Click to switch to automatic tracking" : "Click to switch to manual tracking";

        // Case 4: No permissions
        return "No tracking permissions - Contact SuperAdmin";
    }

