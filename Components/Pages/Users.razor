    private string FormatDuration(double minutes)
    {
        int hours = (int)(minutes / 60);
        int remainingMinutes = (int)(minutes % 60);
        int seconds = (int)((minutes - (int)minutes) * 60);
        return $"{hours}h {remainingMinutes}m {seconds}s";
    }

    private string GetDynamicColor(string key)
    {
        var hash = key.GetHashCode();
        byte r = (byte)(160 + (hash & 0x3F) % 61);
        byte g = (byte)(160 + ((hash >> 6) & 0x3F) % 61);
        byte b = (byte)(160 + ((hash >> 12) & 0x3F) % 61);
        return $"#{r:X2}{g:X2}{b:X2}";
    }

    private async Task LoadAppUsageData()
    {
        if (userId == 0) return;
        isAppUsageLoading = true;
        StateHasChanged();

        currentAppUsagePage = 1;
        selectedAppName = null;

        try
        {
            var appUsageTask = UserService.GetAppUsageByUserIdAsync(
                userId, selectedDate, page: 1, take: appUsagePageSize, usageType: selectedUsageType, userRole: userRole);
            var usageCountTask = UserService.GetDayUsageCountAsync(selectedDate, userId, selectedUsageType);
            var allTitlesTask = UserService.GetAppTitleByDateAsync(selectedDate, userId, page: 1, take: int.MaxValue);
            var appTitlesTask = UserService.GetAppTitleByDateAsync(selectedDate, userId, page: 1, take: takePerPage);
            var categoriesTask = UserService.GetGroupedCategoryKeywordsAsync(userId, selectedDate);

            await Task.WhenAll(appUsageTask, usageCountTask, allTitlesTask, appTitlesTask, categoriesTask);

            initialAppUsageList = appUsageTask.Result;
            totalAppUsageRecords = usageCountTask.Result;
            appUsageList = new List<AppUsage>(initialAppUsageList);
            moreAppUsageAvailable = appUsageList.Count < totalAppUsageRecords;

            totalAppTitleRecords = allTitlesTask.Result.Count;
            initialAppTitleList = appTitlesTask.Result;
            appTitleList = new List<AppTitle>(initialAppTitleList);
            moreTitlesAvailable = true;
            currentTitlePage = 1;

            totalCategoryRecords = categoriesTask.Result.Count;
            initialCategoryList = categoriesTask.Result;
            categoryKeywordGroups = new List<CategoryKeywordGroup>(initialCategoryList);
            currentCategoryPage = 1;
            moreCategoriesAvailable = true;
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading app usage data: {ex.Message}");
            moreAppUsageAvailable = false;
            moreTitlesAvailable = false;
            moreCategoriesAvailable = false;
        }
        finally
        {
            isAppUsageLoading = false;
            StateHasChanged();
        }
    }


