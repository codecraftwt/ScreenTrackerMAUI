    protected override async Task OnInitializedAsync()
    {
        await base.OnInitializedAsync();
        UserService.SetNavigationManager(NavigationManager);

        token = Preferences.Get("authToken", null);
        userRole = null;
        loggedInUserId = 0;

        if (!string.IsNullOrEmpty(token))
        {
            var handler = new JwtSecurityTokenHandler();
            var jwtToken = handler.ReadToken(token) as JwtSecurityToken;
            if (jwtToken != null)
            {
                UserName = jwtToken?.Claims.FirstOrDefault(c => c.Type == "http://schemas.xmlsoap.org/ws/2005/05/identity/claims/name")?.Value;
                userRole = jwtToken?.Claims.FirstOrDefault(c => c.Type == "http://schemas.microsoft.com/ws/2008/06/identity/claims/role")?.Value;
                isAdmin = userRole?.ToLower() == "admin" || userRole?.ToLower() == "superadmin";
                var userIdClaim = jwtToken?.Claims.FirstOrDefault(c => c.Type == "http://schemas.xmlsoap.org/ws/2005/05/identity/claims/nameidentifier")?.Value;

                if (int.TryParse(userIdClaim, out loggedInUserId))
                {
                    this.userId = loggedInUserId;
                }

                var loginTimeClaim = jwtToken.Claims.FirstOrDefault(c => c.Type == "LoginTime")?.Value;
                if (!string.IsNullOrEmpty(loginTimeClaim))
                {
                    LoginTime = loginTimeClaim;
                }
            }
        }

        // Load user's tracking permissions from database (with caching)
        await LoadUserTrackingPermissions();

        // Restore state from UserStateService if available (preserves selections across navigation)
        if (!string.IsNullOrEmpty(UserStateService.SelectedAdminUsername))
        {
            selectedAdminUsername = UserStateService.SelectedAdminUsername;
            admins = UserStateService.Admins;

            if (!string.IsNullOrEmpty(UserStateService.SelectedUsername))
            {
                selectedUsername = UserStateService.SelectedUsername;
                userId = UserStateService.UserId;
                selectedUsageType = UserStateService.SelectedUsageType;
                selectedDate = UserStateService.SelectedDate;
                users = UserStateService.Users;

                // Load data for the restored selection
                await LoadDataAsync(this.userId);
                await LoadAppUsageData();
                await LoadAfkDataAsync(this.userId);
                await LoadCheckinTime(userId);
                await UpdateChart();
            }
            else if (admins != null && admins.Any())
            {
                // If admin is selected but no user, load users for that admin
                selectedAdmin = admins.FirstOrDefault(a => a.username == selectedAdminUsername);
                if (selectedAdmin != null)
                {
                    users = await UserService.GetAllUsersByAdminAsync(selectedAdmin.id, "admin");
                    UserStateService.Users = users;
                }
            }
        }
        else if (UserStateService.UserId > 0 && UserStateService.Users != null && UserStateService.Users.Any())
        {
            Console.WriteLine($"Using UserStateService - UserId: {UserStateService.UserId}, SelectedUsername: {UserStateService.SelectedUsername}");
            this.userId = UserStateService.UserId;
            this.selectedUsername = UserStateService.SelectedUsername;
            this.selectedAdminUsername = UserStateService.SelectedAdminUsername;
            this.selectedUsageType = UserStateService.SelectedUsageType;
            this.selectedDate = UserStateService.SelectedDate;

            admins = UserStateService.Admins;
            users = UserStateService.Users;

            await LoadDataAsync(this.userId);
            await LoadAppUsageData();
            await LoadAfkDataAsync(this.userId);
            await LoadCheckinTime(userId);
            await UpdateChart();

        }
        else
        {
            if (isAdmin && userRole?.ToLower() == "superadmin")
            {
                var allAdmins = await UserService.GetAdminsWithUsersAsync(loggedInUserId);
                // Filter out SuperAdmin users from the list - only show regular Admins
                admins = allAdmins?.Where(a => a.role?.ToLower() != "superadmin").ToList();
                UserStateService.Admins = admins;
                isChartLoading = false;
                isAppUsageLoading = false;
                isAfkDataLoading = false;
            }
            else if (isAdmin)
            {
                Console.WriteLine($"\n========== ADMIN LOGIN BLOCK ==========");
                Console.WriteLine($"Admin login - this.userId: {this.userId}, UserName: {UserName}, loggedInUserId: {loggedInUserId}");
                users = await UserService.GetAllUsersByAdminAsync(this.userId, userRole);
                UserStateService.Users = users;

                // Check if there's a previously saved user selection for this admin
                if (!string.IsNullOrEmpty(UserStateService.SelectedUsername) &&
                    users.Any(u => u.username == UserStateService.SelectedUsername))
                {
                    // Restore the previously selected user
                    selectedUsername = UserStateService.SelectedUsername;
                    var restoredUser = users.FirstOrDefault(u => u.username == selectedUsername);
                    if (restoredUser != null)
                    {
                        this.userId = restoredUser.id;
                        UserStateService.UserId = this.userId;
                        Console.WriteLine($"Restored user selection: {selectedUsername} (ID: {this.userId})");
                    }
                }
                else
                {
                    // No saved selection or saved user not found, default to admin's own account
                    selectedUsername = UserName;
                    UserStateService.SelectedUsername = selectedUsername;

                    // CRITICAL: Ensure userId is set to loggedInUserId for admin's own account
                    if (this.userId == 0 || this.userId != loggedInUserId)
                    {
                        this.userId = loggedInUserId;
                        UserStateService.UserId = this.userId;
                        Console.WriteLine($"Defaulting to admin's own account - userId: {this.userId}");
                    }
                }

                Console.WriteLine($"After setting - userId: {this.userId}, selectedUsername: {selectedUsername}, loggedInUserId: {loggedInUserId}");
                Console.WriteLine($"isManualTrackingAllowed: {isManualTrackingAllowed}, isAutoTrackingAllowed: {isAutoTrackingAllowed}");
                Console.WriteLine($"ShouldShowTrackingButton(): {ShouldShowTrackingButton()}");
                Console.WriteLine($"========================================\n");

                // Load data for the selected user (or admin's own data)
                await LoadDataAsync(this.userId);
                await LoadAppUsageData();
                await LoadAfkDataAsync(this.userId);
                await LoadCheckinTime(this.userId);
                await UpdateChart();

                isChartLoading = false;
                isAppUsageLoading = false;
                isAfkDataLoading = false;
            }
            else
            {
                await LoadDataAsync(this.userId);
                await LoadAppUsageData();
                await LoadAfkDataAsync(this.userId);
                await LoadCheckinTime(userId);
                await UpdateChart();
            }
        }
    }

