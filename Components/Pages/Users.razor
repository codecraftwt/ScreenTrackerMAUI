        StateHasChanged();
        try
        {
            totalAfkMinutes = await UserService.GetAfkLogsTotalAsync(id, selectedDate, userRole, selectedUsageType);

            // UPDATE CHART: For the selected date, use the correct AFK value and recalculate active time
            string selectedDateStr = selectedDate.ToString("yyyy-MM-dd");
            int selectedDateIndex = labels.FindIndex(l => l == selectedDateStr);
            if (selectedDateIndex >= 0)
            {
                // Update AFK data with the correct value from AfkLogs
                if (selectedDateIndex < afkData.Count)
                {
                    afkData[selectedDateIndex] = totalAfkMinutes;
                }
                // Recalculate active time: Total - AFK
                if (selectedDateIndex < activeData.Count)
                {
                    activeData[selectedDateIndex] = Math.Max(0, totalTimeInMinutes - totalAfkMinutes);
                }
            }
        }
        finally
        {
            isAfkDataLoading = false;
            StateHasChanged();
        }
    }

