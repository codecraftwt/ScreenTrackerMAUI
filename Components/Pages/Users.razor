            }
            // }

            // Set initial tracking state based on permissions
            // NOTE: Don't call localStorageModule here - it's not initialized yet in OnInitializedAsync
            // localStorage and StartAll will be handled in OnAfterRenderAsync
            if (isManualTrackingAllowed == true && isAutoTrackingAllowed != true)
            {
                // Case 1: ONLY Manual tracking allowed - Start with ON, user can toggle ON/OFF
                Console.WriteLine("Case 1: Manual tracking only - Setting isOn = true (user can toggle ON/OFF)");
                isOn = true;
            }
            else if (isManualTrackingAllowed != true && isAutoTrackingAllowed == true)
            {
                // Case 2: ONLY Auto tracking allowed - Start automatic tracking
                Console.WriteLine("Case 2: Auto tracking only - Setting isOn = false (button hidden, auto runs)");
                isOn = false;
            }
            else if (isManualTrackingAllowed == true && isAutoTrackingAllowed == true)
            {
                // Case 3: BOTH allowed - Read from Preferences to preserve state across navigation
                // After logout, Preferences is cleared, so it will default to false (OFF/automatic)
                bool savedState = Preferences.Get("IsOnState", false); // Default to false (automatic) for fresh login
                Console.WriteLine($"Case 3: LoadUserTrackingPermissions - Read from Preferences: isOn={savedState}");
                isOn = savedState; // Use the saved state (or false if cleared)

                // IMPORTANT: Also sync to localStorage to ensure NavMenu reads the correct value
                // This prevents NavMenu from showing wrong state after logout+login
                // We'll set it in OnAfterRenderAsync when localStorageModule is available
            }
            else
            {
                // Case 4: NO permissions - OFF (button hidden)
                Console.WriteLine("Case 4: No tracking permissions - Setting isOn = false (button hidden)");
                isOn = false;
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading user tracking permissions: {ex.Message}");
            // Default to false if we can't load permissions
            isManualTrackingAllowed = false;
            isAutoTrackingAllowed = false;
            isOn = false;
        }
