@page "/screenshots"
@page "/screenshots/{date:datetime?}"
@inject NavigationManager NavigationManager
@inject UserService UserService
@inject KeyboardMouseService KeyboardMouseService
@inject IJSRuntime JSRuntime
@using ScreenTracker1.Models
@using ScreenTracker1.Services
@using System.IdentityModel.Tokens.Jwt
@using Microsoft.JSInterop
@using ScreenTracker1
@using ScreenTracker1.Components.Layout
@layout MainLayout
@using NEvaldas.Blazor.Select2


<meta http-equiv="Content-Security-Policy" content="upgrade-insecure-requests">

<div class="container mt-3" @onclick="CloseCustomCalendar">
    <div class="card shadow-sm">
        @* --- START: ALIGNED CARD HEADER --- *@
       <div class="card-header d-flex align-items-center justify-content-between mb-2 p-2">

            @* 1. Back Button *@
            <button @onclick="GoBack" class="btn btn-outline-secondary me-3">
                <i class="fa-solid fa-arrow-left me-2"></i>
                Back
            </button>

            @* 2. Date Picker and Custom Calendar (Crucial Fix: Added d-flex align-items-center to the inner container) *@
            <div class="position-relative d-flex align-items-center">
                <div class="screenshots-page d-flex align-items-center">
                    <input type="date"
                           id="DashboardactivityDate"
                           @onchange="OnDateChanged"
                           value="@selectedDate.ToString("yyyy-MM-dd")"
                           max="@maxSelectableDate"
                           class="stitch-date-picker"
                           @ref="dateInputRef" />
                </div>

                <button class="calendar-toggle-btn ms-2" @onclick:stopPropagation @onclick="ToggleCustomCalendar">
                    <i class="fa fa-calendar"></i>
                </button>

                @if (showCustomCalendar)
                {
                    <div class="custom-calendar-container" @onclick:stopPropagation>
                        <div class="custom-calendar">
                            <div class="calendar-header">
                                <button @onclick="PrevMonth" class="calendar-nav-btn">&lt;</button>
                                <span class="calendar-month">@currentCalendarDate.ToString("MMMM yyyy")</span>
                                <button @onclick="NextMonth" class="calendar-nav-btn" disabled="@(currentCalendarDate.Date.Year > DateTime.Today.Year || (currentCalendarDate.Date.Year == DateTime.Today.Year && currentCalendarDate.Date.Month >= DateTime.Today.Month))">&gt;</button>
                            </div>
                            <div class="calendar-weekdays">
                                <div>Sun</div><div>Mon</div><div>Tue</div><div>Wed</div><div>Thu</div><div>Fri</div><div>Sat</div>
                            </div>
                            <div class="calendar-days">
                                @foreach (var day in calendarDays)
                                {
                                    var isAvailable = availableDates.Any(d => d.Date == day.Date);
                                    var isSelected = selectedDate.Date == day.Date;
                                    var isCurrentMonth = day.Month == currentCalendarDate.Month;
                                    var isToday = day.Date == DateTime.Today;
                                    var isFutureDate = day.Date > DateTime.Today;

                                    var dayClass = "calendar-day";
                                    if (!isCurrentMonth) dayClass += " other-month";
                                    if (isSelected) dayClass += " selected";
                                    if (isToday) dayClass += " today";
                                    if (isFutureDate) dayClass += " disabled";

                                    <div class="@dayClass" @onclick="() => SelectDate(day)">
                                        @day.Day
                                        @if (isAvailable && isCurrentMonth && !isFutureDate)
                                        {
                                            <span class="day-dot">•</span>
                                        }
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                }
            </div>

            @* 3. Refresh Button *@



            @* 4. Usage Type Dropdown (Pushed to the right) *@
          @*    @if (userRole == "Admin" || userRole == "superadmin")
             {
                 <div class="toolbar-section ms-auto d-flex align-items-center">
                     <div class="tooltip-container">
                         <select id="usage-type-select" class="stitch-user-select ms-2" value="@usageType">
                             <option value="all">All</option>
                             <option value="manual">Manual</option>
                             <option value="automatic">Automatic</option>
                         </select>
                         <span class="tooltip-text">Filter data by usage type</span>
                     </div>
                 </div>
             } *@

            @* 5. Refresh Button *@
            <div class="d-flex align-items-center">
                <button class="stitch-refresh-btn"
                        @onclick="OnRefreshClicked"
                        disabled="@isLoading">
                    @if (isLoading)
                    {
                        <i class="fas fa-spinner fa-spin me-2"></i> <span>Loading...</span>
                    }
                    else
                    {
                        <i class="fas fa-sync-alt me-2"></i> <span>Refresh</span>
                    }
                </button>
            </div>
        </div>
        @* --- END: ALIGNED CARD HEADER --- *@

        @if (isLoading)
        {
            <div class="d-flex justify-content-center">
                <div class="spinner-border" role="status">
                    <span class="visually-hidden">Loading...</span>
                </div>
            </div>
        }
        else if (screenshots?.Any() == true)
        {
            @* Display Total Duration *@
            @if (totalDuration > TimeSpan.Zero)
            {
                <div class="total-duration-banner">
                    <i class="fa fa-clock me-2"></i>
                    <span>Total Duration: <strong>@FormatDuration(totalDuration)</strong></span>
                </div>
            }

            <div class="row">
                @foreach (var screenshot in screenshots)
                {
                    <div class="col-6 col-sm-4 col-md-2 screenshot-item">
                        <div class="image-container">
                            <img src="@screenshot.imageUrl" alt="Screenshot" class="img-fluid screenshot-image"
                                 @onclick="() => NavigateToDetailsPage(screenshot.id)" />
                        </div>
                        <div class="screenshot-info">
                            <p>@ConvertToIST(screenshot.captureTime)</p>
                            @{
                                int activeBlocks = GetActiveBlocks(screenshot);
                            }
                            <div class="activity-blocks">
                                @for (int i = 1; i <= 10; i++)
                                {
                                    <span class="block @(i <= activeBlocks ? "active" : "")"></span>
                                }
                            </div>
                            <p>@CalculateActivityScore(screenshot)%</p>
                            @if (currentUser != null && (currentUser.role != "User" || currentUser.isSelected == true))
                            {
                                <button @onclick="() => DeleteScreenshot(screenshot.id)" class="delete-btn">
                                    <i class="fa fa-trash"></i>
                                </button>
                            }
                        </div>
                    </div>
                }
            </div>
            @* NOTE: The bottom pagination block is REMOVED to prevent duplication. *@@*
        <div class="d-flex justify-content-center mt-4">
        <button @onclick="PreviousPage" class="btn btn-secondary" disabled="@(!CanGoToPreviousPage)">Previous</button>
        <span class="mx-3">Page @currentPage</span>
        <button @onclick="NextPage" class="btn btn-secondary" disabled="@(!CanGoToNextPage)">Next</button>
        </div>
        *@
        }
        else
        {
            <p class="no-screenshots">No screenshots found for this date.</p>
        }
    </div>
</div>

@code {
    [Parameter]
    public DateTime? Date { get; set; }

    [Parameter]
    [SupplyParameterFromQuery]
    public int ViewedUserId { get; set; }

    [Parameter]
    [SupplyParameterFromQuery]
    public string startTime { get; set; }

    [Parameter]
    [SupplyParameterFromQuery]
    public string endTime { get; set; }

    @using System.Timers

    private List<Screenshots> screenshots;
    private List<DateTime> availableDates = new List<DateTime>();
    private string token;
    private int userId = 0;
    private DateTime selectedDate;
    private bool isLoading;
    private User currentUser;
    private string userRole;
    private string maxSelectableDate = DateTime.Today.ToString("yyyy-MM-dd");
    private TimeSpan totalDuration = TimeSpan.Zero;

    private bool showCustomCalendar = false;
    private DateTime currentCalendarDate;
    private List<DateTime> calendarDays = new List<DateTime>();
    private ElementReference dateInputRef;

    private System.Timers.Timer activityTimer;
    private DotNetObjectReference<ScreenshotsPage> objRef;

    private bool isSelect2UsageTypeInitialized = false;
    private bool isTimeFiltered = false;
    private TimeSpan? filterStartTime;
    private TimeSpan? filterEndTime;

    [Parameter]
    [SupplyParameterFromQuery]
    public string usageType { get; set; } = "all";

    protected override async Task OnInitializedAsync()
    {
        selectedDate = Date ?? DateTime.Today;
        currentCalendarDate = selectedDate;

        Console.WriteLine($"ScreenshotsPage OnInitializedAsync - Date: {selectedDate:yyyy-MM-dd}, ViewedUserId: {ViewedUserId}, StartTime: {startTime}, EndTime: {endTime}");

        token = Preferences.Get("authToken", null);
        if (!string.IsNullOrEmpty(token))
        {
            var handler = new JwtSecurityTokenHandler();
            if (handler.ReadToken(token) is JwtSecurityToken jwtToken)
            {
                // Get the logged-in user's ID from JWT token (default/fallback)
                var userIdClaim = jwtToken.Claims.FirstOrDefault(c => c.Type == "http://schemas.xmlsoap.org/ws/2005/05/identity/claims/nameidentifier")?.Value;
                if (int.TryParse(userIdClaim, out int id))
                {
                    userId = id;
                }

                var roleClaim = jwtToken.Claims.FirstOrDefault(c => c.Type == "http://schemas.microsoft.com/ws/2008/06/identity/claims/role")?.Value;
                if (!string.IsNullOrEmpty(roleClaim))
                {
                    userRole = roleClaim;
                }
            }
        }
        else
        {
            Console.WriteLine("User not authenticated.");
        }

        // --- TIMER INITIALIZATION AND START ---
        // This runs the HandleMinuteTick method every 60 seconds (1 minute).
        activityTimer = new System.Timers.Timer(60000);
        activityTimer.Elapsed += HandleMinuteTick;
        activityTimer.AutoReset = true;
        activityTimer.Enabled = true;
        // --------------------------------------
    }

    protected override async Task OnParametersSetAsync()
    {
        Console.WriteLine($"ScreenshotsPage OnParametersSetAsync - Date: {Date}, ViewedUserId: {ViewedUserId}, StartTime: {startTime}, EndTime: {endTime}");

        // Update selected date if Date parameter changed
        if (Date.HasValue)
        {
            selectedDate = Date.Value;
            currentCalendarDate = selectedDate;
        }

        // Parse time filter parameters if provided
        if (!string.IsNullOrEmpty(startTime) && !string.IsNullOrEmpty(endTime))
        {
            if (TimeSpan.TryParse(startTime, out TimeSpan start) && TimeSpan.TryParse(endTime, out TimeSpan end))
            {
                filterStartTime = start;
                filterEndTime = end;
                isTimeFiltered = true;
                Console.WriteLine($"Time filter applied: {start} to {end}");
            }
            else
            {
                Console.WriteLine($"Failed to parse time parameters: startTime={startTime}, endTime={endTime}");
            }
        }
        else
        {
            isTimeFiltered = false;
            filterStartTime = null;
            filterEndTime = null;
            Console.WriteLine("No time filter parameters provided");
        }

        // Priority 1: If ViewedUserId is provided from URL (e.g., from Report or AdminUsers page), use it FIRST
        // This is the most explicit and should override everything else
        if (ViewedUserId != 0)
        {
            userId = ViewedUserId;
            Console.WriteLine($"Using ViewedUserId from URL: {userId}");
        }
        // Priority 2: If App.SelectedUserId is set, use it (for internal navigation)
        else if (App.SelectedUserId != 0)
        {
            userId = App.SelectedUserId;
            Console.WriteLine($"Using App.SelectedUserId: {userId}");
        }

        // Load data if we have a valid userId
        if (userId != 0 && token != null)
        {
            currentUser = await UserService.GetUserByIdAsync(userId);
            StateHasChanged();
            if (currentUser != null)
            {
                Console.WriteLine($"Current User Role: {currentUser.role}");
            }
            availableDates = await UserService.GetAvailableDatesAsync(userId);
            await LoadScreenshotsAsync(usageType);
            GenerateCalendarDays();
        }
    }
    private async Task OnRefreshClicked()
    {
        await LoadScreenshotsAsync(usageType);
    }
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await JSRuntime.InvokeVoidAsync("eval", $@"document.getElementById('DashboardactivityDate').setAttribute('max', '{maxSelectableDate}');");
        }

        if (userRole == "Admin" || userRole == "superadmin")
        {
            if (objRef == null)
            {
                objRef = DotNetObjectReference.Create(this);
            }

            if (!isSelect2UsageTypeInitialized)
            {
                try
                {
                    await JSRuntime.InvokeVoidAsync("initializeSelect2", "usage-type-select", objRef);
                    isSelect2UsageTypeInitialized = true;
                }
                catch (Exception ex)
                {
                    Console.WriteLine($"Error initializing Usage Type Select2: {ex.Message}");
                }
            }
        }
    }

    [JSInvokable]
    public async Task OnSelect2Changed(string elementId, string value)
    {
        if (elementId == "usage-type-select")
        {
            isLoading = true;
            StateHasChanged();
            usageType = value;
            await LoadScreenshotsAsync(usageType);
            isLoading = false;
            StateHasChanged();
        }
    }

    public void Dispose()
    {
        objRef?.Dispose();

        // --- TIMER DISPOSE LOGIC ADDED ---
        if (activityTimer != null)
        {
            activityTimer.Elapsed -= HandleMinuteTick; // Unsubscribe
            activityTimer.Stop();
            activityTimer.Dispose();
        }
        // ---------------------------------
    }

    private void GenerateCalendarDays()
    {
        calendarDays.Clear();
        var firstDay = new DateTime(currentCalendarDate.Year, currentCalendarDate.Month, 1);
        var lastDay = firstDay.AddMonths(1).AddDays(-1);
        var startDate = firstDay.AddDays(-(int)firstDay.DayOfWeek);
        var endDate = lastDay.AddDays(6 - (int)lastDay.DayOfWeek);

        for (var date = startDate; date <= endDate; date = date.AddDays(1))
        {
            calendarDays.Add(date);
        }
    }

    private void ToggleCustomCalendar()
    {
        showCustomCalendar = !showCustomCalendar;
        if (showCustomCalendar)
        {
            currentCalendarDate = selectedDate;
            GenerateCalendarDays();
        }
    }

    private void CloseCustomCalendar()
    {
        showCustomCalendar = false;
    }

    private void PrevMonth()
    {
        currentCalendarDate = currentCalendarDate.AddMonths(-1);
        GenerateCalendarDays();
    }

    private void NextMonth()
    {
        currentCalendarDate = currentCalendarDate.AddMonths(1);
        GenerateCalendarDays();
    }

    private async Task SelectDate(DateTime date)
    {
        if (date.Date <= DateTime.Today)
        {
            selectedDate = date;
            showCustomCalendar = false;
            
            // Clear time filters when date is selected from custom calendar
            isTimeFiltered = false;
            filterStartTime = null;
            filterEndTime = null;
            startTime = null;
            endTime = null;
            
            await LoadScreenshotsAsync(usageType);
        }
    }
    // In ScreenshotsPage.razor @code block
    private void NavigateToDetailsPage(int screenshotId)
    {
        NavigationManager.NavigateTo($"/screenshot-details/{screenshotId}?date={selectedDate:yyyy-MM-dd}&usageType={usageType}&viewedUserId={userId}"); // <--- ADD THIS
    }

    private async Task GoBack()
    {
        await JSRuntime.InvokeVoidAsync("history.back");
    }

    private void CalculateTotalDurationFromScreenshots()
    {
        // Each screenshot represents 10 minutes of tracking
        // Total duration = number of screenshots × 10 minutes
        if (screenshots != null && screenshots.Any())
        {
            int totalMinutes = screenshots.Count * 10;
            totalDuration = TimeSpan.FromMinutes(totalMinutes);
        }
        else
        {
            totalDuration = TimeSpan.Zero;
        }
    }

    private string FormatDuration(TimeSpan duration)
    {
        if (duration.TotalDays >= 1)
        {
            return $"{(int)duration.TotalDays}d {(int)duration.Hours}h {duration.Minutes}m";
        }
        else if (duration.TotalHours >= 1)
        {
            return $"{(int)duration.TotalHours}h {duration.Minutes}m";
        }
        else
        {
            return $"{(int)duration.TotalMinutes}m";
        }
    }

    private void NavigateHome() => NavigationManager.NavigateTo("/users");

    private async Task LoadScreenshotsAsync(string usageType = "all")
    {
        isLoading = true;
        // Notify the UI to show the loading spinner immediately
        StateHasChanged();

        try
        {
            // Fetch ALL screenshots for the selected date (no pagination)
            // Using a large take value to get all records
            var basicScreenshots = await UserService.GetImagesByDateAsync(
                userId,
                selectedDate,
                1,      // skip
                10000,  // take - large number to get all screenshots
                usageType,
                startTime,
                endTime
            );

            Console.WriteLine($"[LoadScreenshots] Fetched {basicScreenshots?.Count ?? 0} basic screenshots from API");

            // Create a temporary list to hold the detailed, processed results
            var newScreenshots = new List<Screenshots>();

            if (basicScreenshots?.Any() == true)
            {
                // Reverse the order to show oldest first (FCFS - First Come First Serve)
                var reversedScreenshots = basicScreenshots.AsEnumerable().Reverse().ToList();
                
                Console.WriteLine($"[LoadScreenshots] Reversed list has {reversedScreenshots.Count} screenshots");
                
                // Process the detailed data, adding results to the temporary list
                foreach (var shot in reversedScreenshots)
                {
                    var detailed = await KeyboardMouseService.GetImageActivityDataAsync(shot.id);
                    if (detailed == null)
                    {
                        Console.WriteLine($"[LoadScreenshots] Screenshot ID {shot.id} returned null from GetImageActivityDataAsync, using original");
                    }
                    newScreenshots.Add(detailed ?? shot);
                }
                
                Console.WriteLine($"[LoadScreenshots] Final processed screenshots count: {newScreenshots.Count}");
            }

            // Update the component's state list ONLY after all processing is complete
            screenshots = newScreenshots;

            // Calculate total duration based on number of screenshots (each = 10 minutes)
            CalculateTotalDurationFromScreenshots();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading screenshots: {ex.Message}");
            // Optionally clear the list on error
            screenshots = new List<Screenshots>();
            totalDuration = TimeSpan.Zero;
        }
        finally
        {
            isLoading = false;
            // Notify the UI to hide the spinner and display the new data
            StateHasChanged();
        }
    }

    private async Task OnDateChanged(ChangeEventArgs e)
    {
        if (DateTime.TryParse(e.Value?.ToString(), out var newDate))
        {
            selectedDate = newDate;
            
            // Clear time filters when date changes manually
            isTimeFiltered = false;
            filterStartTime = null;
            filterEndTime = null;
            startTime = null;
            endTime = null;
            
            await LoadScreenshotsAsync(usageType);
        }
    }



    private async Task DeleteScreenshot(int screenshotId)
    {
        if (await UserService.DeleteScreenshotAsync(screenshotId))
        {
            await LoadScreenshotsAsync(usageType);
        }
        else
        {
            Console.WriteLine("Failed to delete screenshot.");
        }
    }

    private void HandleMinuteTick(object sender, ElapsedEventArgs e)
    {

        var (keyboardClicks, mouseClicks) = KeyboardMouseService.GetAndResetClicks();

        Console.WriteLine($"Minute Tick: Logging activity for user {userId}. Keyboard: {keyboardClicks}, Mouse: {mouseClicks}");

    }

    private string ConvertToIST(DateTime captureTime)
    {
        var istZone = TimeZoneInfo.FindSystemTimeZoneById("India Standard Time");
        var utcTime = DateTime.SpecifyKind(captureTime, DateTimeKind.Utc);
        return TimeZoneInfo.ConvertTimeFromUtc(utcTime, istZone).ToString("hh:mm tt");
    }

    private int CalculateActivityScore(Screenshots screenshot)
    {
        // int score = (int)((double)(screenshot.keyboardClicks + screenshot.mouseClicks) / 1000 * 100);
          int score = (int)((double)(screenshot.keyboardClicks + screenshot.mouseClicks) / 300 * 100);
        return Math.Clamp(score, 0, 100);
    }

    private int GetActiveBlocks(Screenshots screenshot)
    {
        // int blocks = (int)Math.Round((double)(screenshot.keyboardClicks + screenshot.mouseClicks) / 1000 * 10);
        int blocks = (int)((double)(screenshot.keyboardClicks + screenshot.mouseClicks) / 300 * 10);
        return Math.Clamp(blocks, 0, 10);
    }
}