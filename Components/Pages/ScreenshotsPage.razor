@page "/screenshots"
@page "/screenshots/{date:datetime?}"

@inject NavigationManager NavigationManager
@inject UserService UserService
@inject KeyboardMouseService KeyboardMouseService
@inject IJSRuntime JSRuntime

@using ScreenTracker1.Models
@using ScreenTracker1.Services
@using System.IdentityModel.Tokens.Jwt
@using Microsoft.JSInterop
@using Microsoft.Maui.Storage
@using ScreenTracker1
@using ScreenTracker1.Components.Layout
@using System.Timers

@implements IDisposable
@layout MainLayout

<header class="page-navbar">
    <div class="page-navbar-copy">
        <span class="page-navbar-eyebrow">Time and Activity Overview</span>
        <h1>Screenshots</h1>
    </div>
</header>

<div class="container mt-3" @onclick="CloseCustomCalendar">
    <div class="card shadow-sm">

        <div class="card-header d-flex align-items-center justify-content-between mb-2 p-2">
            <button type="button" class="btn-back" @onclick="GoBack" title="Go Back">
                <i class="fas fa-arrow-left" aria-hidden="true"></i>
                <span>Back</span>
            </button>

            <div class="position-relative d-flex align-items-center">
                <div class="screenshots-page d-flex align-items-center">
                    <input type="date"
                           id="DashboardactivityDate"
                           @onchange="OnDateChanged"
                           value="@selectedDate.ToString("yyyy-MM-dd")"
                           max="@maxSelectableDate"
                           class="stitch-date-picker"
                           @ref="dateInputRef" />
                </div>

                <button class="calendar-toggle-btn ms-2"
                        @onclick:stopPropagation
                        @onclick="ToggleCustomCalendar">
                    <i class="fa fa-calendar"></i>
                </button>

                @if (showCustomCalendar)
                {
                    <div class="custom-calendar-container" @onclick:stopPropagation>
                        <div class="custom-calendar">
                            <div class="calendar-header">
                                <button @onclick="PrevMonth" class="calendar-nav-btn">&lt;</button>

                                <span class="calendar-month">
                                    @currentCalendarDate.ToString("MMMM yyyy")
                                </span>

                                <button @onclick="NextMonth"
                                        class="calendar-nav-btn"
                                        disabled="@(currentCalendarDate.Date.Year > DateTime.Today.Year ||
                                                    (currentCalendarDate.Date.Year == DateTime.Today.Year &&
                                                     currentCalendarDate.Date.Month >= DateTime.Today.Month))">
                                    &gt;
                                </button>
                            </div>

                            <div class="calendar-weekdays">
                                <div>Sun</div>
                                <div>Mon</div>
                                <div>Tue</div>
                                <div>Wed</div>
                                <div>Thu</div>
                                <div>Fri</div>
                                <div>Sat</div>
                            </div>

                            <div class="calendar-days">
                                @foreach (var day in calendarDays)
                                {
                                    var isAvailable = availableDates.Any(d => d.Date == day.Date);
                                    var isSelected = selectedDate.Date == day.Date;
                                    var isCurrentMonth = day.Month == currentCalendarDate.Month;
                                    var isToday = day.Date == DateTime.Today;
                                    var isFutureDate = day.Date > DateTime.Today;

                                    var dayClass = "calendar-day";

                                    if (!isCurrentMonth)
                                    {
                                        dayClass += " other-month";
                                    }

                                    if (isSelected)
                                    {
                                        dayClass += " selected";
                                    }

                                    if (isToday)
                                    {
                                        dayClass += " today";
                                    }

                                    if (isFutureDate)
                                    {
                                        dayClass += " disabled";
                                    }

                                    <div class="@dayClass" @onclick="() => SelectDate(day)">
                                        @day.Day

                                        @if (isAvailable && isCurrentMonth && !isFutureDate)
                                        {
                                            <span class="day-dot">•</span>
                                        }
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                }
            </div>

            <div class="d-flex align-items-center">
                <button class="stitch-refresh-btn"
                        @onclick="OnRefreshClicked"
                        disabled="@isLoading">
                    @if (isLoading)
                    {
                        <i class="fas fa-spinner fa-spin me-2"></i>
                        <span>Loading...</span>
                    }
                    else
                    {
                        <i class="fas fa-sync-alt me-2"></i>
                        <span>Refresh</span>
                    }
                </button>
            </div>
        </div>

        @if (isLoading && screenshots?.Any() != true)
        {
            <div class="d-flex justify-content-center my-4">
                <div class="spinner-border" role="status">
                    <span class="visually-hidden">Loading...</span>
                </div>
            </div>
        }
        else if (screenshots?.Any() == true)
        {
            @if (totalDuration > TimeSpan.Zero)
            {
                <div class="total-duration-banner">
                    <i class="fa fa-clock me-2"></i>
                    <span>Total Duration: <strong>@FormatDuration(totalDuration)</strong></span>
                </div>
            }

            <div class="row" id="screenshot-grid">
                @foreach (var screenshot in screenshots)
                {
                    <div class="col-6 col-sm-4 col-md-2 screenshot-item">
                        <div class="image-container">
                            <img src="@GetImageUrl(screenshot)"
                                 alt="Screenshot"
                                 style="max-width: 100%; max-height: 150px; border: 2px solid #007bff; border-radius: 4px;"
                                 @onclick="() => NavigateToDetailsPage(screenshot.id)"
                                 onerror="this.style.border='2px solid red'; this.alt='Failed to load'; console.error('Failed image:', this.src);"
                                 onload="console.log('Loaded image:', this.src);" />
                        </div>

                        <div class="screenshot-info">
                            <p>@ConvertToIST(screenshot.captureTime)</p>

                            @{
                                int activeBlocks = GetActiveBlocks(screenshot);
                            }

                            <div class="activity-blocks">
                                @for (int i = 1; i <= 10; i++)
                                {
                                    <span class="block @(i <= activeBlocks ? "active" : "")"></span>
                                }
                            </div>

                            <p>@CalculateActivityScore(screenshot)%</p>

                            @{
                                bool canDelete =
                                    userRole == "Admin" ||
                                    userRole == "superadmin" ||
                                    (userRole == "User" &&
                                     loggedInUser?.isSelected == true &&
                                     loggedInUserId == screenshot.userId);
                            }

                            @if (canDelete)
                            {
                                <button @onclick="() => ConfirmAndDeleteScreenshot(screenshot.id)"
                                        class="delete-btn">
                                    <i class="fa fa-trash"></i>
                                </button>
                            }
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <p class="no-screenshots">No screenshots found for this date.</p>
        }

        @* Enable only while debugging *@
        @* 
        @if (!string.IsNullOrEmpty(diagnosticMessage))
        {
            <div style="margin-top: 16px; padding: 8px 12px; background: #f8f9fa; border: 1px solid #dee2e6; border-radius: 4px; font-size: 11px; font-family: monospace; color: #333; white-space: pre-wrap; max-height: 300px; overflow: auto;">
                @diagnosticMessage
            </div>
        }
        *@
    </div>
</div>

@code {
    [Parameter]
    public DateTime? Date { get; set; }

    [Parameter]
    [SupplyParameterFromQuery]
    public int ViewedUserId { get; set; }

    [Parameter]
    [SupplyParameterFromQuery]
    public string? startTime { get; set; }

    [Parameter]
    [SupplyParameterFromQuery]
    public string? endTime { get; set; }

    [Parameter]
    [SupplyParameterFromQuery]
    public string usageType { get; set; } = "all";

    private List<Screenshots> screenshots = new List<Screenshots>();
    private List<DateTime> availableDates = new List<DateTime>();

    private string? token;
    private int userId = 0;
    private DateTime selectedDate = DateTime.Today;
    private bool isLoading = false;
    private bool isScreenshotRequestRunning = false;

    private User? currentUser;
    private int loggedInUserId;
    private User? loggedInUser;
    private string userRole = "";

    private string maxSelectableDate = DateTime.Today.ToString("yyyy-MM-dd");
    private TimeSpan totalDuration = TimeSpan.Zero;

    private bool showCustomCalendar = false;
    private DateTime currentCalendarDate = DateTime.Today;
    private List<DateTime> calendarDays = new List<DateTime>();
    private ElementReference dateInputRef;

    private System.Timers.Timer? activityTimer;
    private DotNetObjectReference<ScreenshotsPage>? objRef;

    private bool isSelect2UsageTypeInitialized = false;
    private bool isTimeFiltered = false;
    private TimeSpan? filterStartTime;
    private TimeSpan? filterEndTime;

    private string diagnosticMessage = string.Empty;

    private const string BaseImageUrl = "http://10.0.3.55:90/uploads/";

    protected override async Task OnInitializedAsync()
    {
        try
        {
            selectedDate = Date ?? DateTime.Today;
            currentCalendarDate = selectedDate;

            token = Preferences.Get("authToken", null);

            if (!string.IsNullOrEmpty(token))
            {
                var handler = new JwtSecurityTokenHandler();

                if (handler.ReadToken(token) is JwtSecurityToken jwtToken)
                {
                    var userIdClaim = jwtToken.Claims
                        .FirstOrDefault(c => c.Type == "http://schemas.xmlsoap.org/ws/2005/05/identity/claims/nameidentifier")
                        ?.Value;

                    if (int.TryParse(userIdClaim, out int id))
                    {
                        userId = id;
                        loggedInUserId = id;
                    }

                    var roleClaim = jwtToken.Claims
                        .FirstOrDefault(c => c.Type == "http://schemas.microsoft.com/ws/2008/06/identity/claims/role")
                        ?.Value;

                    if (!string.IsNullOrEmpty(roleClaim))
                    {
                        userRole = roleClaim;
                    }
                }

                if (loggedInUserId != 0)
                {
                    loggedInUser = await UserService.GetUserByIdAsync(loggedInUserId);
                }
            }

            activityTimer = new System.Timers.Timer(60000);
            activityTimer.Elapsed += HandleMinuteTick;
            activityTimer.AutoReset = true;
            activityTimer.Enabled = true;
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[OnInitializedAsync] Error: {ex.Message}");
            diagnosticMessage = $"OnInitializedAsync Error: {ex.Message}";
            isLoading = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    protected override async Task OnParametersSetAsync()
    {
        try
        {
            if (Date.HasValue)
            {
                selectedDate = Date.Value;
                currentCalendarDate = selectedDate;
            }

            if (!string.IsNullOrWhiteSpace(startTime) && !string.IsNullOrWhiteSpace(endTime))
            {
                if (TimeSpan.TryParse(startTime, out TimeSpan start) &&
                    TimeSpan.TryParse(endTime, out TimeSpan end))
                {
                    filterStartTime = start;
                    filterEndTime = end;
                    isTimeFiltered = true;
                }
                else
                {
                    isTimeFiltered = false;
                    filterStartTime = null;
                    filterEndTime = null;
                }
            }
            else
            {
                isTimeFiltered = false;
                filterStartTime = null;
                filterEndTime = null;
            }

            if (ViewedUserId != 0)
            {
                userId = ViewedUserId;
            }
            else if (App.SelectedUserId != 0)
            {
                userId = App.SelectedUserId;
            }

            GenerateCalendarDays();

            if (userId != 0 && !string.IsNullOrEmpty(token))
            {
                currentUser = await UserService.GetUserByIdAsync(userId);
                availableDates = await UserService.GetAvailableDatesAsync(userId);

                await LoadScreenshotsAsync(usageType);
            }
            else
            {
                diagnosticMessage = $"Cannot load data. userId={userId}, token={(string.IsNullOrEmpty(token) ? "empty" : "found")}";
                isLoading = false;
                await InvokeAsync(StateHasChanged);
            }
        }
        catch (Exception ex)
        {
            diagnosticMessage = $"OnParametersSetAsync Error: {ex.Message}";
            Console.WriteLine($"[OnParametersSetAsync] Error: {ex.Message}");
            isLoading = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        try
        {
            if (firstRender)
            {
                await JSRuntime.InvokeVoidAsync(
                    "eval",
                    $@"document.getElementById('DashboardactivityDate')?.setAttribute('max', '{maxSelectableDate}');"
                );
            }

            if (userRole == "Admin" || userRole == "superadmin")
            {
                if (objRef == null)
                {
                    objRef = DotNetObjectReference.Create(this);
                }

                if (!isSelect2UsageTypeInitialized)
                {
                    try
                    {
                        await JSRuntime.InvokeVoidAsync("initializeSelect2", "usage-type-select", objRef);
                        isSelect2UsageTypeInitialized = true;
                    }
                    catch (Exception ex)
                    {
                        Console.WriteLine($"Error initializing Usage Type Select2: {ex.Message}");
                    }
                }
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[OnAfterRenderAsync] Error: {ex.Message}");
        }
    }

    private async Task LoadScreenshotsAsync(string usageType = "all")
    {
        if (isScreenshotRequestRunning)
        {
            return;
        }

        isScreenshotRequestRunning = true;
        isLoading = true;
        await InvokeAsync(StateHasChanged);

        try
        {
            if (userId == 0)
            {
                diagnosticMessage += "❌ User ID is 0. Cannot load screenshots.\n";
                screenshots = new List<Screenshots>();
                totalDuration = TimeSpan.Zero;
                return;
            }

            var startTimeFilter = isTimeFiltered && filterStartTime.HasValue
                ? filterStartTime.Value.ToString(@"hh\:mm")
                : null;

            var endTimeFilter = isTimeFiltered && filterEndTime.HasValue
                ? filterEndTime.Value.ToString(@"hh\:mm")
                : null;

            diagnosticMessage +=
                $"Calling GetImagesByDateAsync for userId={userId}, date={selectedDate:yyyy-MM-dd}, " +
                $"start={startTimeFilter}, end={endTimeFilter}, usageType={usageType}\n";

            Console.WriteLine(
                $"Loading screenshots: userId={userId}, date={selectedDate:yyyy-MM-dd}, " +
                $"isTimeFiltered={isTimeFiltered}, start={startTimeFilter}, end={endTimeFilter}, usageType={usageType}"
            );

            var basicScreenshots = await UserService.GetImagesByDateAsync(
                userId,
                selectedDate,
                1,
                10000,
                usageType,
                startTimeFilter,
                endTimeFilter
            );

            diagnosticMessage += $"API returned. Count: {basicScreenshots?.Count ?? 0}\n";

            if (basicScreenshots?.Any() != true)
            {
                screenshots = new List<Screenshots>();
                totalDuration = TimeSpan.Zero;
                return;
            }

            screenshots = basicScreenshots
                .AsEnumerable()
                .Reverse()
                .ToList();

            CalculateTotalDurationFromScreenshots();

            foreach (var shot in screenshots)
            {
                Console.WriteLine(
                    $"Screenshot #{shot.id}: {GetImageUrl(shot)} | UTC: {shot.captureTime:o} | IST: {ConvertToIST(shot.captureTime)}"
                );
            }
        }
        catch (Exception ex)
        {
            diagnosticMessage += $"❌ LoadScreenshotsAsync Error: {ex.Message}\n";
            Console.WriteLine($"[LoadScreenshotsAsync] Error: {ex.Message}");
            Console.WriteLine(ex.StackTrace);

            screenshots = new List<Screenshots>();
            totalDuration = TimeSpan.Zero;
        }
        finally
        {
            isLoading = false;
            isScreenshotRequestRunning = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private string GetImageUrl(Screenshots screenshot)
    {
        if (screenshot == null || string.IsNullOrEmpty(screenshot.imageUrl))
        {
            return string.Empty;
        }

        string url = screenshot.imageUrl;

        if (url.StartsWith("http", StringComparison.OrdinalIgnoreCase) ||
            url.StartsWith("data:", StringComparison.OrdinalIgnoreCase))
        {
            return url;
        }

        return BaseImageUrl + url;
    }

    private async Task OnRefreshClicked()
    {
        try
        {
            await LoadScreenshotsAsync(usageType);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[OnRefreshClicked] Error: {ex.Message}");
            diagnosticMessage = $"Refresh Error: {ex.Message}";
            isLoading = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    [JSInvokable]
    public async Task OnSelect2Changed(string elementId, string value)
    {
        if (elementId == "usage-type-select")
        {
            usageType = value;
            await LoadScreenshotsAsync(usageType);
        }
    }

    private async Task OnDateChanged(ChangeEventArgs e)
    {
        try
        {
            if (DateTime.TryParse(e.Value?.ToString(), out var newDate))
            {
                selectedDate = newDate;

                isTimeFiltered = false;
                filterStartTime = null;
                filterEndTime = null;
                startTime = null;
                endTime = null;

                await LoadScreenshotsAsync(usageType);
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[OnDateChanged] Error: {ex.Message}");
            diagnosticMessage = $"Date Change Error: {ex.Message}";
            isLoading = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private void GenerateCalendarDays()
    {
        calendarDays.Clear();

        var firstDay = new DateTime(currentCalendarDate.Year, currentCalendarDate.Month, 1);
        var lastDay = firstDay.AddMonths(1).AddDays(-1);

        var startDate = firstDay.AddDays(-(int)firstDay.DayOfWeek);
        var endDate = lastDay.AddDays(6 - (int)lastDay.DayOfWeek);

        for (var date = startDate; date <= endDate; date = date.AddDays(1))
        {
            calendarDays.Add(date);
        }
    }

    private void ToggleCustomCalendar()
    {
        showCustomCalendar = !showCustomCalendar;

        if (showCustomCalendar)
        {
            currentCalendarDate = selectedDate;
            GenerateCalendarDays();
        }
    }

    private void CloseCustomCalendar()
    {
        showCustomCalendar = false;
    }

    private void PrevMonth()
    {
        currentCalendarDate = currentCalendarDate.AddMonths(-1);
        GenerateCalendarDays();
    }

    private void NextMonth()
    {
        currentCalendarDate = currentCalendarDate.AddMonths(1);
        GenerateCalendarDays();
    }

    private async Task SelectDate(DateTime date)
    {
        if (date.Date <= DateTime.Today)
        {
            selectedDate = date;
            showCustomCalendar = false;

            isTimeFiltered = false;
            filterStartTime = null;
            filterEndTime = null;
            startTime = null;
            endTime = null;

            await LoadScreenshotsAsync(usageType);
        }
    }

    private void NavigateToDetailsPage(int screenshotId)
    {
        NavigationManager.NavigateTo(
            $"/screenshot-details/{screenshotId}?date={selectedDate:yyyy-MM-dd}&usageType={usageType}&viewedUserId={userId}"
        );
    }

    private async Task GoBack()
    {
        await JSRuntime.InvokeVoidAsync("navigationHistory.goBack", "/users");
    }

    private async Task ConfirmAndDeleteScreenshot(int screenshotId)
    {
        try
        {
            bool confirmed = await JSRuntime.InvokeAsync<bool>(
                "confirm",
                "Are you sure you want to delete this screenshot?"
            );

            if (!confirmed)
            {
                return;
            }

            bool deleted = await UserService.DeleteScreenshotAsync(screenshotId);

            if (deleted)
            {
                await LoadScreenshotsAsync(usageType);
            }
            else
            {
                Console.WriteLine("Failed to delete screenshot.");
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[ConfirmAndDeleteScreenshot] Error: {ex.Message}");
        }
    }

    private void CalculateTotalDurationFromScreenshots()
    {
        if (screenshots != null && screenshots.Any())
        {
            int totalMinutes = screenshots.Count * 10;
            totalDuration = TimeSpan.FromMinutes(totalMinutes);
        }
        else
        {
            totalDuration = TimeSpan.Zero;
        }
    }

    private string FormatDuration(TimeSpan duration)
    {
        if (duration.TotalDays >= 1)
        {
            return $"{(int)duration.TotalDays}d {(int)duration.Hours}h {duration.Minutes}m";
        }

        if (duration.TotalHours >= 1)
        {
            return $"{(int)duration.TotalHours}h {duration.Minutes}m";
        }

        return $"{(int)duration.TotalMinutes}m";
    }

    private TimeZoneInfo GetIndiaTimeZone()
    {
        try
        {
            return TimeZoneInfo.FindSystemTimeZoneById("India Standard Time");
        }
        catch
        {
            try
            {
                return TimeZoneInfo.FindSystemTimeZoneById("Asia/Kolkata");
            }
            catch
            {
                return TimeZoneInfo.Local;
            }
        }
    }

    private string ConvertToIST(DateTime captureTime)
    {
        try
        {
            var istZone = GetIndiaTimeZone();

            DateTime utcTime = captureTime.Kind == DateTimeKind.Utc
                ? captureTime
                : DateTime.SpecifyKind(captureTime, DateTimeKind.Utc);

            return TimeZoneInfo
                .ConvertTimeFromUtc(utcTime, istZone)
                .ToString("hh:mm tt");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[ConvertToIST] Error: {ex.Message}");
            return captureTime.ToString("hh:mm tt");
        }
    }

    private int CalculateActivityScore(Screenshots screenshot)
    {
        if (screenshot == null)
        {
            return 0;
        }

        int score = (int)((double)(screenshot.keyboardClicks + screenshot.mouseClicks) / 300 * 100);
        return Math.Clamp(score, 0, 100);
    }

    private int GetActiveBlocks(Screenshots screenshot)
    {
        if (screenshot == null)
        {
            return 0;
        }

        int blocks = (int)((double)(screenshot.keyboardClicks + screenshot.mouseClicks) / 300 * 10);
        return Math.Clamp(blocks, 0, 10);
    }

    private void HandleMinuteTick(object? sender, ElapsedEventArgs e)
    {
        try
        {
            var (keyboardClicks, mouseClicks) = KeyboardMouseService.GetAndResetClicks();

            Console.WriteLine(
                $"Minute Tick: User {userId}, Keyboard: {keyboardClicks}, Mouse: {mouseClicks}"
            );
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[HandleMinuteTick] Error: {ex.Message}");
        }
    }

    public void Dispose()
    {
        objRef?.Dispose();

        if (activityTimer != null)
        {
            activityTimer.Elapsed -= HandleMinuteTick;
            activityTimer.Stop();
            activityTimer.Dispose();
        }
    }
}
