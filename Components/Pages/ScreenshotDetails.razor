@page "/screenshot-details/{ImageId:int}"
@using ScreenTracker1.Models
@using ScreenTracker1.Services
@using System.Text.Json
@using System.IdentityModel.Tokens.Jwt
@inject KeyboardMouseService KeyboardMouseService
@inject UserService UserService
@inject NavigationManager NavigationManager
@inject IJSRuntime JSRuntime
@implements IDisposable

<style>
    .image-container {
        position: relative;
    }

    .nav-button {
        background-color: transparent !important;
        border: none !important;
        color: rgba(255, 255, 255, 0.7);
        font-size: 2.5rem;
        z-index: 10;
        transition: color 0.3s ease-in-out, transform 0.3s ease-in-out;
        text-shadow: 1px 1px 3px rgba(0, 0, 0, 0.5);
    }

        .nav-button:hover {
            color: white;
            transform: scale(1.1);
        }

        .nav-button:disabled {
            color: rgba(255, 255, 255, 0.3) !important;
            cursor: not-allowed;
        }
</style>

@if (!string.IsNullOrEmpty(errorMessage))
{
    <p class="text-danger">@errorMessage</p>
}
else if (screenshots == null)
{
    <p>Loading...</p>
}
else
{
    <div style="font-family: 'Comfortaa';">
        <button type="button" @onclick="BackToScreenshots" class="btn-back" title="Go Back">
            <i class="fas fa-arrow-left" aria-hidden="true"></i>
            <span>Back</span>
        </button>

        <div class="row">
            <div class="col-md-9">
                @if (!string.IsNullOrEmpty(screenshots.imageUrl))
                {
                    <div class="image-container text-center">
                        @if (hasPreviousScreenshot)
                        {
                            <button @onclick='() => LoadRelativeScreenshotAsync("previous")'
                                    class="btn nav-button position-absolute top-50 start-0 translate-middle-y"
                                    title="Previous">
                                <i class="fa fa-chevron-left"></i>
                            </button>
                        }
                        else
                        {
                            <button class="btn nav-button position-absolute top-50 start-0 translate-middle-y" disabled title="Previous">
                                <i class="fa fa-chevron-left"></i>
                            </button>
                        }

                        @if (_isDetailImageLoading && _detailImageBlobUrl == null)
                        {
                            <div class="text-center p-5">
                                <div class="spinner-border" role="status">
                                    <span class="visually-hidden">Loading image...</span>
                                </div>
                            </div>
                        }
                        else
                        {
                            <img src="@(_detailImageBlobUrl ?? string.Empty)"
                                 alt="Screenshot"
                                 class="img-fluid screenshot-image"
                                 data-detail-img="1"
                                 style="max-width: 80%; height: auto; border: 1px solid var(--border-color); border-radius: 4px; padding: 4px;" />
                        }

                        @if (hasNextScreenshot)
                        {
                            <button @onclick='() => LoadRelativeScreenshotAsync("next")'
                                    class="btn nav-button position-absolute top-50 end-0 translate-middle-y"
                                    title="Next">
                                <i class="fa fa-chevron-right"></i>
                            </button>
                        }
                        else
                        {
                            <button class="btn nav-button position-absolute top-50 end-0 translate-middle-y" disabled title="Next">
                                <i class="fa fa-chevron-right"></i>
                            </button>
                        }
                    </div>
                }
                else
                {
                    <p>No image available.</p>
                }
            </div>

            <div class="col-md-3">
                <div class="card mb-3">
                    <div class="card-header card-header-background">
                        <h5 class="card-title mb-0">Screenshot Details</h5>
                    </div>
                    <div class="card-body">
                        <p><strong>Time:</strong> @FormatTimestamp(screenshots.captureTime)</p>
                        <p><strong>Keyboard Clicks:</strong> @screenshots.keyboardClicks</p>
                        <p><strong>Mouse Clicks:</strong> @screenshots.mouseClicks</p>
                    </div>
                </div>

                <div class="card">
                    <div class="card-header card-header-background">
                        <h5 class="card-title mb-0">Activity Details</h5>
                    </div>
                    <div class="card-body p-0">
                        @if (minuteActivity?.Any() == true)
                        {
                            <div class="activity-scroll" style="max-height: 400px; overflow-y: auto;">
                                <table class="table table-sm mb-0">
                                    <thead class="sticky-top">
                                        <tr>
                                            <th>Time</th>
                                            <th>K</th>
                                            <th>M</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var entry in minuteActivity.Values.OrderBy(e => e.Timestamp))
                                        {
                                            <tr>
                                                <td>@FormatTimeOnly(entry.Timestamp)</td>
                                                <td>@entry.Keyboard</td>
                                                <td>@entry.Mouse</td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                        else
                        {
                            <p class="p-3 mb-0">No activity data</p>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public int ImageId { get; set; }
    [Parameter][SupplyParameterFromQuery] public DateTime? Date { get; set; }
    [Parameter][SupplyParameterFromQuery] public string UsageType { get; set; } = "all";
    [Parameter][SupplyParameterFromQuery] public int? ViewedUserId { get; set; }

    private Screenshots screenshots;
    private Dictionary<string, MinuteActivity> minuteActivity;
    private string errorMessage;
    private int userId; // This variable stores the Logged-in User's ID (Admin's ID)
    private string token;

    private bool hasNextScreenshot;
    private bool hasPreviousScreenshot;

    // Blob URL for the detail image (bypasses WKWebView data URI size limitation)
    private string? _detailImageBlobUrl = null;
    private bool _isDetailImageLoading = false;
    // Static HttpClient: avoids creating/destroying NSUrlSession on macOS
    private static readonly HttpClient _detailHttp = new HttpClient();

    // FIX 1: Change 'loggedInUserId' to 'userId' in the TargetUserId property
    // This property correctly determines if we should view the SELECTED user (App.SelectedUserId)
    // or the LOGGED-IN Admin (userId).
    private int TargetUserId => ViewedUserId.GetValueOrDefault() > 0
        ? ViewedUserId.Value
        : App.SelectedUserId != 0 ? App.SelectedUserId : userId;


    protected override async Task OnInitializedAsync()
    {
        token = Preferences.Get("authToken", null);
        if (!string.IsNullOrEmpty(token))
        {
            var handler = new JwtSecurityTokenHandler();
            if (handler.ReadToken(token) is JwtSecurityToken jwtToken)
            {
                var userIdClaim = jwtToken.Claims.FirstOrDefault(c => c.Type == "http://schemas.xmlsoap.org/ws/2005/05/identity/claims/nameidentifier")?.Value;
                if (int.TryParse(userIdClaim, out int id))
                {
                    userId = id; // userId is correctly set here (Admin's ID)
                }
            }
        }

        // FIX 2: Remove the redundant 'targetId' calculation block.
        // The TargetUserId property now handles this automatically.
        // int targetId = 0;
        // if (App.SelectedUserId != 0)
        // {
        //     targetId = App.SelectedUserId;
        // }
        // else
        // {
        //     targetId = userId;
        // }

        await LoadImageDataAsync();
        await CheckForRelativeScreenshotsAsync();
    }

    private async Task LoadDetailImageAsync()
    {
        if (screenshots == null)
            return;

        // Reset stale image before loading new one
        await RevokeDetailBlobUrlAsync();
        _detailImageBlobUrl = null;
        _isDetailImageLoading = true;
        await InvokeAsync(StateHasChanged);

        try
        {
            string? dataToProcess = null;
            string mimeType = "image/jpeg";

            // Step 1: Check if the model already has embedded base64 data
            string? embeddedBase64 = screenshots.GetBase64ImageUri();
            if (!string.IsNullOrEmpty(embeddedBase64))
            {
                dataToProcess = embeddedBase64;
                Console.WriteLine($"[DetailImage] Using embedded base64 for screenshot #{screenshots.id}");
            }
            // Step 2: Check if imageUrl is already a data URI
            else if (!string.IsNullOrEmpty(screenshots.imageUrl) &&
                     screenshots.imageUrl.StartsWith("data:", StringComparison.OrdinalIgnoreCase))
            {
                dataToProcess = screenshots.imageUrl;
                Console.WriteLine($"[DetailImage] Using imageUrl data URI for screenshot #{screenshots.id}");
            }
            // Step 3: Download image from server via native HttpClient (supports auth headers)
            else
            {
                string fullUrl = App.GetFullImageUrl(screenshots.imageUrl);
                if (string.IsNullOrEmpty(fullUrl))
                {
                    Console.WriteLine($"[DetailImage] No image URL for screenshot #{screenshots.id}");
                    return;
                }

                var request = new HttpRequestMessage(HttpMethod.Get, fullUrl);
                string? authToken = Preferences.Get("authToken", "");
                if (!string.IsNullOrWhiteSpace(authToken))
                    request.Headers.Authorization = new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", authToken);

                var response = await _detailHttp.SendAsync(request);
                if (!response.IsSuccessStatusCode)
                {
                    Console.WriteLine($"[DetailImage] HTTP {(int)response.StatusCode} for '{screenshots.imageUrl}'");
                    return;
                }

                var bytes = await response.Content.ReadAsByteArrayAsync();
                var base64 = Convert.ToBase64String(bytes);

                if (fullUrl.EndsWith(".jpg", StringComparison.OrdinalIgnoreCase) || fullUrl.EndsWith(".jpeg", StringComparison.OrdinalIgnoreCase))
                    mimeType = "image/jpeg";
                else if (fullUrl.EndsWith(".gif", StringComparison.OrdinalIgnoreCase))
                    mimeType = "image/gif";
                else if (fullUrl.EndsWith(".webp", StringComparison.OrdinalIgnoreCase))
                    mimeType = "image/webp";
                else if (fullUrl.EndsWith(".png", StringComparison.OrdinalIgnoreCase))
                    mimeType = "image/png";

                dataToProcess = $"data:{mimeType};base64,{base64}";
                Console.WriteLine($"[DetailImage] Downloaded {bytes.Length} bytes for screenshot #{screenshots.id}");
            }

            // Create blob URL from the data via JavaScript interop (bypasses WKWebView data URI limitation)
            if (!string.IsNullOrEmpty(dataToProcess))
            {
                // Determine MIME type from data URI if not already set
                if (dataToProcess.StartsWith("data:image/png", StringComparison.OrdinalIgnoreCase))
                    mimeType = "image/png";
                else if (dataToProcess.StartsWith("data:image/gif", StringComparison.OrdinalIgnoreCase))
                    mimeType = "image/gif";
                else if (dataToProcess.StartsWith("data:image/webp", StringComparison.OrdinalIgnoreCase))
                    mimeType = "image/webp";

                var blobUrl = await JSRuntime.InvokeAsync<string>(
                    "createScreenshotBlobUrl", screenshots.id, dataToProcess, mimeType);

                if (!string.IsNullOrEmpty(blobUrl))
                {
                    _detailImageBlobUrl = blobUrl;
                    Console.WriteLine($"[DetailImage] Created blob URL for screenshot #{screenshots.id}");
                }
                else
                {
                    Console.WriteLine($"[DetailImage] Failed to create blob URL for screenshot #{screenshots.id}");
                }
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[DetailImage] Error: {ex.Message}");
        }
        finally
        {
            _isDetailImageLoading = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task LoadImageDataAsync()
    {
        try
        {
            
            screenshots = await KeyboardMouseService.GetImageActivityDataAsync(ImageId);

            if (screenshots == null)
            {
                errorMessage = "No data found for the selected screenshot.";
                return;
            }

            var generatedUrl = App.GetFullImageUrl(screenshots.imageUrl);
            Console.WriteLine($"[ScreenshotDetails] Loaded screenshot #{screenshots.id}: imageUrl='{screenshots.imageUrl}', image_path='{screenshots.image_path}', fullUrl='{generatedUrl}'");

            // Start loading image as blob URL (bypasses WKWebView data URI rendering limitation)
            _ = LoadDetailImageAsync();

            if (!string.IsNullOrWhiteSpace(screenshots.minuteActivityData))
            {
                var options = new JsonSerializerOptions { PropertyNameCaseInsensitive = true };
                minuteActivity = JsonSerializer.Deserialize<Dictionary<string, MinuteActivity>>(screenshots.minuteActivityData, options);
            }
            else
            {
                minuteActivity = new Dictionary<string, MinuteActivity>();
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Error loading screenshot details: {ex.Message}";
        }
    }

    private async Task CheckForRelativeScreenshotsAsync()
    {
        if (screenshots == null || screenshots.captureTime == default)
        {
            hasPreviousScreenshot = false;
            hasNextScreenshot = false;
            return;
        }

        try
        {
            // FIX: Uses TargetUserId which correctly holds the SELECTED user's ID
            var nextCheck = await UserService.GetRelativeScreenshotAsync(TargetUserId, screenshots.id, screenshots.captureTime, "next", UsageType);
            hasNextScreenshot = nextCheck != null;

            var previousCheck = await UserService.GetRelativeScreenshotAsync(TargetUserId, screenshots.id, screenshots.captureTime, "previous", UsageType);
            hasPreviousScreenshot = previousCheck != null;
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error checking for relative screenshots: {ex.Message}");
            hasPreviousScreenshot = false;
            hasNextScreenshot = false;
        }
    }

    private async Task LoadRelativeScreenshotAsync(string direction)
    {
        if (screenshots == null || screenshots.captureTime == default)
        {
            errorMessage = "Cannot navigate without a valid screenshot and capture time.";
            return;
        }

        // FIX: Uses TargetUserId which correctly holds the SELECTED user's ID
        var relativeScreenshot = await UserService.GetRelativeScreenshotAsync(
            TargetUserId, screenshots.id, screenshots.captureTime, direction, UsageType);

        if (relativeScreenshot != null)
        {
            ImageId = relativeScreenshot.id;

            await LoadImageDataAsync();
            await CheckForRelativeScreenshotsAsync();

            errorMessage = null;

            var dateParam = Date.HasValue ? Date.Value.ToString("yyyy-MM-dd") : null;
            var viewedUserParam = ViewedUserId.GetValueOrDefault() > 0
                ? $"&viewedUserId={ViewedUserId.Value}"
                : string.Empty;
            var detailsUrl = $"/screenshot-details/{ImageId}?date={dateParam}&usageType={UsageType}{viewedUserParam}";

            NavigationManager.NavigateTo(detailsUrl, new NavigationOptions
            {
                ReplaceHistoryEntry = true
            });
        }
        else
        {
            errorMessage = $"No {direction} screenshot found.";
            if (direction == "previous")
            {
                hasPreviousScreenshot = false;
            }
            else
            {
                hasNextScreenshot = false;
            }
        }
    }

    private async Task BackToScreenshots()
    {
        var dateParam = Date.HasValue ? Date.Value.ToString("yyyy-MM-dd") : null;
        var viewedUserParam = ViewedUserId.GetValueOrDefault() > 0
            ? $"&viewedUserId={ViewedUserId.Value}"
            : string.Empty;
        var fallbackUrl = $"/screenshots/{dateParam}?usageType={UsageType}{viewedUserParam}";
        await JSRuntime.InvokeVoidAsync("navigationHistory.goBack", fallbackUrl);
    }

    private string FormatTimestamp(DateTime? timestamp) => timestamp?.ToLocalTime().ToString("h:mm:ss tt") ?? "N/A";
    private string FormatTimeOnly(DateTime? timestamp) => timestamp?.ToLocalTime().ToString("h:mm:ss") ?? "N/A";

    /// <summary>
    /// Revokes the detail image blob URL to prevent memory leaks.
    /// </summary>
    private async Task RevokeDetailBlobUrlAsync()
    {
        if (!string.IsNullOrEmpty(_detailImageBlobUrl))
        {
            try
            {
                // Revoke using the screenshot ID if we have one
                if (screenshots?.id > 0)
                {
                    await JSRuntime.InvokeVoidAsync("revokeScreenshotBlobUrl", screenshots.id);
                }
            }
            catch { }
            _detailImageBlobUrl = null;
        }
    }

    public void Dispose()
    {
        // Blob URLs are scoped to the document and are automatically cleaned up
        // when the WebView navigates away. No explicit JS cleanup needed here.
        _detailImageBlobUrl = null;
    }
}
