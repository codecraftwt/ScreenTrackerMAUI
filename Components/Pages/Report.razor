    private async Task LoadHistory(int pageNumber = 1)
    {
        try
        {
            CurrentPage = pageNumber;
            // Show loading state while fetching
            Trackers = null;
            StateHasChanged();

            if (UserRole?.ToLower() == "admin" || UserRole?.ToLower() == "superadmin")
            {
                
                // Determine which API to call based on the case
                if (UserRole?.ToLower() == "superadmin")
                {
                    // Case 1: All Admins selected (SelectedAdminId=0, SelectedUserId=0)
                    if (SelectedAdminId == 0 && SelectedUserId == 0)
                    {
                        
                        // Fetch all data without admin filter
                        var pagedResult = await UserService.GetAllUsersReportAsync(
                            FromDate.Date,
                            ToDate.Date.AddDays(1).AddTicks(-1),
                            string.Empty,
                            null, // No admin filter - get all
                            1, // Get first page
                            1000, // Large page size to get all records
                            selectedUsageType);

                        // Filter to show only admin users' data
                        var adminIds = AllAdmins.Select(a => a.id).ToHashSet();
                        var adminOnlyTrackers = pagedResult.Items?
                            .Where(t => t.User != null && adminIds.Contains(t.User.id))
                            .ToList() ?? new List<DailyTrackerWithUserDto>();
                        
                        // Apply client-side pagination
                        TotalRecords = adminOnlyTrackers.Count();
                        Trackers = adminOnlyTrackers
                            .Skip((CurrentPage - 1) * PageSize)
                            .Take(PageSize)
                            .ToList();
                    }
                    // Case 2: Specific Admin + All Users (SelectedAdminId>0, SelectedUserId=0)
                    else if (SelectedAdminId > 0 && SelectedUserId == 0)
                    {
                        // Console.WriteLine($"[DEBUG] Case 2: Admin {SelectedAdminId} + All Users - Calling GetAllUsersReportAsync with adminId={SelectedAdminId}");
                        var pagedResult = await UserService.GetAllUsersReportAsync(
                            FromDate.Date,
                            ToDate.Date.AddDays(1).AddTicks(-1),
                            string.Empty,
                            SelectedAdminId, // Filter by this admin
                            CurrentPage,
                            PageSize,
                            selectedUsageType);

                        Trackers = pagedResult.Items ?? new List<DailyTrackerWithUserDto>();
                        TotalRecords = pagedResult.TotalCount;
                    }
                    // Case 3 or 4: Specific User selected (SelectedUserId>0)
                    else if (SelectedUserId > 0)
                    {
                        var selectedUser = AllUsers.FirstOrDefault(u => u.id == SelectedUserId);
                        bool isUserAdmin = selectedUser?.role?.ToLower() == "admin";
                        
                        // Use GetTodayDailyTrackerAsync for specific user (whether admin or regular user)
                        var pagedResult = await UserService.GetTodayDailyTrackerAsync(
                            SelectedUserId, // Specific userId
                            FromDate.Date,
                            ToDate.Date.AddDays(1).AddTicks(-1),
                            string.Empty,
                            CurrentPage,
                            PageSize,
                            selectedUsageType);

                        Trackers = pagedResult.Items ?? new List<DailyTrackerWithUserDto>();
                        TotalRecords = pagedResult.TotalCount;
                    }
                }
                else // Admin role
                {
                    // For admin role:
                    // Case 2: All Users (SelectedUserId=0) - Show all users under this admin
                    // Case 3: Admin selects themselves (SelectedUserId == loggedInUserId)
                    // Case 4: Admin selects a specific user (SelectedUserId > 0)
                    
                    if (SelectedUserId == 0)
                    {
                        // Case 2: Show all users under this admin
                        var pagedResult = await UserService.GetAllUsersReportAsync(
                            FromDate.Date,
                            ToDate.Date.AddDays(1).AddTicks(-1),
                            string.Empty,
                            loggedInUserId, // This admin's ID
                            CurrentPage,
                            PageSize,
                            selectedUsageType);

                        Trackers = pagedResult.Items ?? new List<DailyTrackerWithUserDto>();
                        TotalRecords = pagedResult.TotalCount;
                    }
                    else
                    {
                        // Case 3 or 4: Specific user selected
                        var selectedUser = AllUsers.FirstOrDefault(u => u.id == SelectedUserId);
                        bool isAdminThemselves = SelectedUserId == loggedInUserId;
                        
                        // Use GetTodayDailyTrackerAsync for specific user
                        var pagedResult = await UserService.GetTodayDailyTrackerAsync(
                            SelectedUserId,
                            FromDate.Date,
                            ToDate.Date.AddDays(1).AddTicks(-1),
                            string.Empty,
                            CurrentPage,
                            PageSize,
                            selectedUsageType);

                        Trackers = pagedResult.Items ?? new List<DailyTrackerWithUserDto>();
                        TotalRecords = pagedResult.TotalCount;
                    }
                }
            }
            else
            {
                var pagedResult = await UserService.GetTodayDailyTrackerAsync(
                    loggedInUserId,
                    FromDate.Date,
                    ToDate.Date.AddDays(1).AddTicks(-1),
                    string.Empty,
                    CurrentPage,
                    PageSize,
                    selectedUsageType);

                Trackers = pagedResult.Items ?? new List<DailyTrackerWithUserDto>();
                TotalRecords = pagedResult.TotalCount;
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading history: {ex.Message}");
            Trackers = new List<DailyTrackerWithUserDto>();
            TotalRecords = 0;
        }
        finally
        {
            StateHasChanged();
        }
    }


    private IEnumerable<int> GetPageNumbers()
    {
        var pageNumbers = new List<int>();
        var startPage = Math.Max(1, CurrentPage - (int)Math.Floor(PaginationDisplaySize / 2.0));
        var endPage = Math.Min(TotalPages, startPage + PaginationDisplaySize - 1);

        for (int i = startPage; i <= endPage; i++)
        {
            pageNumbers.Add(i);
        }

        if (startPage > 1)
        {
            pageNumbers.Insert(0, -1); 
        }

        if (endPage < TotalPages)
        {
            pageNumbers.Add(-1); 
        }

        return pageNumbers;
    }

    private void PreviousPage()
    {
        if (CurrentPage > 1)
        {
            LoadHistory(CurrentPage - 1);
        }
    }

    private void NextPage()
    {
        if (CurrentPage < TotalPages)
        {
            LoadHistory(CurrentPage + 1);
        }
    }

    private string FormatDuration(TimeSpan duration)
    {
        if (duration.TotalDays >= 1)
        {
            return $"{(int)duration.TotalDays} days {duration.Hours} hours {duration.Minutes} minutes";
        }
        return $"{duration.Hours} hours {duration.Minutes} minutes";
    }

    private TimeSpan GetTotalDuration()
    {
        var totalDuration = new TimeSpan();
        foreach (var trackerDto in Trackers)
        {
            if (trackerDto.Tracker.StartTracker.HasValue && trackerDto.Tracker.EndTracker.HasValue)
            {
                totalDuration += trackerDto.Tracker.EndTracker.Value - trackerDto.Tracker.StartTracker.Value;
            }
        }
        return totalDuration;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        
        var dotNetRef = DotNetObjectReference.Create(this);
        
        // Wait a bit for DOM to be ready
        await Task.Delay(100);
        
        // Initialize Admin Select2 dropdown first (for superadmin)
        if (UserRole?.ToLower() == "superadmin" && !isSelect2AdminInitialized && AllAdmins != null && AllAdmins.Any())
        {
            try
            {
                await JSRuntime.InvokeVoidAsync("initializeSelect2", "admin-dropdown", dotNetRef);
                isSelect2AdminInitialized = true;
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Error initializing Admin Select2: {ex.Message}");
            }
        }

        // Initialize User Select2 dropdown when users are loaded
        if (!isSelect2UserInitialized && AllUsers != null && AllUsers.Any())
        {
            try
            {
                await Task.Delay(50); // Small delay to ensure DOM is ready
                await JSRuntime.InvokeVoidAsync("initializeSelect2", "user-dropdown", dotNetRef);
                isSelect2UserInitialized = true;
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Error initializing User Select2: {ex.Message}");
            }
        }

        // Initialize Usage Type Select2 dropdown
        if (!isSelect2UsageTypeInitialized)
        {
            try
            {
                await JSRuntime.InvokeVoidAsync("initializeSelect2", "usage-type-dropdown", dotNetRef);
                isSelect2UsageTypeInitialized = true;
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Error initializing Usage Type Select2: {ex.Message}");
            }
        }
    }

    private async Task LoadAllAdmins()
    {
        try
        {
            if (UserRole?.ToLower() == "superadmin")
            {
                // Get all admins (excluding superadmins)
                var allUsers = await UserService.GetAllUsersAsync();
                AllAdmins = allUsers?.Where(u => u.role?.ToLower() == "admin").ToList() ?? new List<User>();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading admins: {ex.Message}");
            AllAdmins = new List<User>();
        }
    }

    private async Task LoadUsersForAdmin(int adminId)
    {
        try
        {
            // Load users for the selected admin
            var users = await UserService.GetAllUsersByAdminAsync(adminId, "admin") ?? new List<User>();
            
            // Get the admin's own details to include them in the dropdown (for Case 3)
            var adminDetails = await UserService.GetUserByIdAsync(adminId);
            
            if (adminDetails != null)
            {
                // Check if admin is already in the users list
                bool adminExists = users.Any(u => u.id == adminId);
                
                if (!adminExists)
                {
                    // Admin not in list, add them
                    var combinedList = new List<User> { adminDetails };
                    combinedList.AddRange(users);
                    AllUsers = combinedList;
                }
                else
                {
                    // Admin already in list, just use the users list
                    AllUsers = users;
                }
            }
            else
            {
                AllUsers = users;
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading users for admin: {ex.Message}");
            AllUsers = new List<User>();
        }
    }

    private async Task OnAdminChanged(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out int adminId))
        {
            SelectedAdminId = adminId;
            SelectedUserId = 0; // Reset user selection
            AllUsers = new List<User>(); // Clear users
            isSelect2UserInitialized = false; // Reset Select2 flag

            // Load users for selected admin (only if a specific admin is selected)
            if (adminId > 0)
            {
                await LoadUsersForAdmin(adminId);
            }

            StateHasChanged();
        }
    }



    [JSInvokable]
    public async Task OnSelect2Changed(string elementId, string value)
    {
        if (elementId == "usage-type-dropdown")
        {
            selectedUsageType = value;
            await LoadHistory(1);  
            StateHasChanged(); // Force UI update
        }
        else if (elementId == "admin-dropdown")
        {
            if (int.TryParse(value, out int adminId))
            {
                SelectedAdminId = adminId;
                SelectedUserId = 0; // Reset user selection
                AllUsers = new List<User>(); // Clear users
                isSelect2UserInitialized = false; // Reset Select2 flag

                // Load users for selected admin
                if (adminId > 0)
                {
                    await LoadUsersForAdmin(adminId);
                }

                await LoadHistory(1);
                StateHasChanged();
                
                // Reinitialize Select2 for user dropdown after DOM update
                await Task.Delay(100);
                try
                {
                    var dotNetRef = DotNetObjectReference.Create(this);
                    await JSRuntime.InvokeVoidAsync("initializeSelect2", "user-dropdown", dotNetRef);
                    isSelect2UserInitialized = true;
                }
                catch (Exception ex)
                {
                    Console.WriteLine($"Error reinitializing User Select2: {ex.Message}");
                }
            }
        }
        else if (elementId == "user-dropdown")
        {
            if (int.TryParse(value, out int userId))
            {
                SelectedUserId = userId;
                await LoadHistory(1);  
                StateHasChanged(); // Force UI update
            }
        }
    }
}