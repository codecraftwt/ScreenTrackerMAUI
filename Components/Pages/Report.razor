@page "/rptTime/{UserId:int}"
@page "/rptTime"
@inject IJSRuntime JSRuntime
@inject UserService UserService
@inject NavigationManager NavigationManager
@using ScreenTracker1.DTOS
@using ScreenTracker1.Services
@using ScreenTracker1.Models
@using System.IdentityModel.Tokens.Jwt
@using System.Security.Claims
@using Microsoft.Maui.ApplicationModel

<div class="report-container">
    <div class="card">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <button class="btn-back" @onclick="GoBack" title="Go Back">
                <i class="fas fa-arrow-left"></i> Back
            </button>
            <h2 class="title mb-0">Daily Tracker History</h2>
            <div></div>
        </div>

        <div class="filters">
               @* <label>Date Range</label> *@
            <div class="filters-row">
                <InputDate @bind-Value="FromDate" class="input-date" />
                <span class="to-text">to</span>
                <InputDate @bind-Value="ToDate" class="input-date" />

                @if (UserRole?.ToLower() == "admin" || UserRole?.ToLower() == "superadmin")
                {
                    @if (UserRole?.ToLower() == "superadmin")
                    {
                        <label class="labels-colors">Select Admin</label>
                        <select id="admin-dropdown" @onchange="OnAdminChanged" class="stitch-user-selectreport ms-2">
                            <option value="0">All Admins</option>
                            @foreach (var admin in AllAdmins)
                            {
                                <option value="@admin.id" selected="@(SelectedAdminId == admin.id)">@(admin.firstName + " " + admin.lastName)</option>
                            }
                        </select>
                    }

                    <label class="labels-colors">Select User</label>
                    <select id="user-dropdown" @bind="SelectedUserId" class="stitch-user-selectreport ms-2">
                        @if (SelectedAdminId == 0 && UserRole?.ToLower() == "superadmin")
                        {
                            <option value="0">Select an admin first</option>
                        }
                        else
                        {
                            <option value="0">All Users</option>
                            @foreach (var user in AllUsers)
                            {
                                <option value="@user.id">@(user.firstName + " " + user.lastName) @(user.role?.ToLower() == "admin" ? "(Admin)" : "")</option>
                            }
                        }
                    </select>

                    <label class="labels-colors">Usage Type</label>
                    <select id="usage-type-dropdown" @bind="selectedUsageType" class="stitch-user-selectreport ms-2">
                        <option value="all">All</option>
                        <option value="manual">Manual</option>
                        <option value="automatic">Automatic</option>
                    </select>
                }

                <button class="btn-load" @onclick="() => LoadHistory(1)"> <i class="fas fa-cloud-download-alt"></i> Load</button>
            </div>
        </div>

        @if (Trackers == null)
        {
            <div class="loading">Loading...</div>
        }
        else if (!Trackers.Any())
        {
            <div class="no-data">No tracker data available for the selected range.</div>
        }
        else
        {
            <div class="table-wrapper">
                <table class="tracker-table">
                    <thead>
                        <tr>
                            <th>Date</th>
                            <th>Name</th>
                            <th>Start Time</th>
                            <th>End Time</th>
                            <th>Type</th>
                            <th>Duration</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var trackerDto in Trackers)
                        {
                            var tz = TimeZoneInfo.FindSystemTimeZoneById("India Standard Time");
                            var tracker = trackerDto.Tracker;

                            <tr>
                                <td>@TimeZoneInfo.ConvertTimeFromUtc(tracker.Date, tz).ToString("MMM dd, yyyy")</td>
                                <td>@(trackerDto.User?.firstName + " " + trackerDto.User?.lastName)</td>
                                <td>
                                    @(tracker.StartTracker.HasValue
                                        ? TimeZoneInfo.ConvertTimeFromUtc(tracker.StartTracker.Value, tz).ToString("hh:mm tt")
                                        : "-")
                                </td>
                                <td>
                                    @(tracker.EndTracker.HasValue
                                        ? TimeZoneInfo.ConvertTimeFromUtc(tracker.EndTracker.Value, tz).ToString("hh:mm tt")
                                        : "-")
                                </td>

                                <td>@trackerDto.Tracker.StartMode</td>

                                <td class="duration">
                                    @if (tracker.StartTracker.HasValue && tracker.EndTracker.HasValue)
                                    {
                                        var duration = tracker.EndTracker.Value - tracker.StartTracker.Value;
                                        <span @onclick="() => NavigateToScreenshots(trackerDto.User?.id ?? 0, tracker.Date, tracker.StartTracker.Value, tracker.EndTracker.Value)" 
                                              style="cursor: pointer; text-decoration: underline;" 
                                              title="View screenshots for this time period">
                                            @(duration.TotalMinutes >= 0 ? FormatDuration(duration) : "-")
                                        </span>
                                    }
                                    else
                                    {
                                        <span>-</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            @if (TotalPages > 1)
            {
                <nav aria-label="Page navigation example" class="d-flex justify-content-center mt-4">
                    <ul class="pagination">
                        <li class="page-item @(CurrentPage == 1 ? "disabled" : "")">
                            <a class="page-link" href="#" @onclick="PreviousPage" @onclick:preventDefault aria-label="Previous">
                                <span aria-hidden="true">&laquo;</span>
                            </a>
                        </li>

                        @foreach (var pageNumber in GetPageNumbers())
                        {
                            @if (pageNumber == -1) 
                            {
                                <li class="page-item disabled">
                                    <a class="page-link" href="#">...</a>
                                </li>
                            }
                            else
                            {
                                <li class="page-item @(pageNumber == CurrentPage ? "active" : "")">
                                    <a class="page-link" href="#" @onclick="() => LoadHistory(pageNumber)" @onclick:preventDefault>
                                        @pageNumber
                                    </a>
                                </li>
                            }
                        }

                        <li class="page-item @(CurrentPage == TotalPages ? "disabled" : "")">
                            <a class="page-link" href="#" @onclick="NextPage" @onclick:preventDefault aria-label="Next">
                                <span aria-hidden="true">&raquo;</span>
                            </a>
                        </li>
                    </ul>
                </nav>
            }
            <div class="summary flex justify-between p-2 bg-gray-100 rounded-lg mt-4">
                <span>Showing <b>@Trackers.Count</b> of <b>@TotalRecords</b> records</span>
                <span><b>@FormatDuration(GetTotalDuration())</b> total</span>
            </div>
        }
    </div>
</div>

@code {
    [Parameter] public int UserId { get; set; }

    private DateTime FromDate { get; set; } = DateTime.Now.Date.AddDays(-30); // Show last 30 days by default
    private DateTime ToDate { get; set; } = DateTime.Now.Date;
    private List<DailyTrackerWithUserDto> Trackers { get; set; } = new();
    private string? UserRole;
    private int SelectedUserId { get; set; } = 0;
    private int SelectedAdminId { get; set; } = 0;
    private List<User> AllUsers { get; set; } = new();
    private List<User> AllAdmins { get; set; } = new();
    private int loggedInUserId;
    private int CurrentPage { get; set; } = 1;
    private int PageSize { get; set; } = 10;
    private int TotalRecords { get; set; }
    private int TotalPages => (int)Math.Ceiling((double)TotalRecords / PageSize);
    private int PaginationDisplaySize { get; set; } = 5; 
    [Parameter]
    [SupplyParameterFromQuery]
    public string UsageType { get; set; } = "all";
    private string selectedUsageType = "all";
    private bool isSelect2UserInitialized = false;
    private bool isSelect2AdminInitialized = false;
    private bool isSelect2UsageTypeInitialized = false;

    private void NavigateToHome() => NavigationManager.NavigateTo("/active-users");

    private async void GoBack()
    {
        // Use JavaScript to go back to the previous page in browser history
        await JSRuntime.InvokeVoidAsync("history.back");
    }

    private void NavigateToScreenshots(int userId, DateTime date, DateTime startTime, DateTime endTime)
    {
        var tz = TimeZoneInfo.FindSystemTimeZoneById("India Standard Time");

        // 1. Ensure we are working with IST
        var istDate = TimeZoneInfo.ConvertTimeFromUtc(date, tz);
        var istStartTime = TimeZoneInfo.ConvertTimeFromUtc(startTime, tz);
        var istEndTime = TimeZoneInfo.ConvertTimeFromUtc(endTime, tz);

        // 2. Format: yyyy-MM-dd and HH:mm
        var dateStr = istDate.ToString("yyyy-MM-dd");
        var startTimeStr = istStartTime.ToString("HH:mm"); // Results in "15:50"
        var endTimeStr = istEndTime.ToString("HH:mm");   // Results in "15:51"

        // 3. Use lowercase 'viewedUserId' to match AdminUsers.razor pattern
        NavigationManager.NavigateTo($"/screenshots/{dateStr}?viewedUserId={userId}&startTime={startTimeStr}&endTime={endTimeStr}");
    }

    protected override async Task OnInitializedAsync()
    {
        selectedUsageType = UsageType ?? "all";

        await LoadUserDataAndRoleAsync();
        
        // Load admins first for superadmin
        if (UserRole?.ToLower() == "superadmin")
        {
            await LoadAllAdmins();
        }
        else if (UserRole?.ToLower() == "admin")
        {
            // For admin, load their users directly
            await LoadUsersForAdmin(loggedInUserId);
        }
        
        await LoadHistory(1);
    }

    private async Task LoadUserDataAndRoleAsync()
    {
        var token = Preferences.Get("authToken", null);
        if (!string.IsNullOrEmpty(token))
        {
            var handler = new JwtSecurityTokenHandler();
            var jwtToken = handler.ReadToken(token) as JwtSecurityToken;

            if (jwtToken != null)
            {
                UserRole = jwtToken.Claims.FirstOrDefault(c => c.Type == ClaimTypes.Role)?.Value;
                var userIdClaim = jwtToken.Claims.FirstOrDefault(c => c.Type == ClaimTypes.NameIdentifier)?.Value;

                if (int.TryParse(userIdClaim, out int id))
                    loggedInUserId = id;
            }
        }
    }

