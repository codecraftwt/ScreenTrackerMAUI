		<PackageReference Include="Radzen.Blazor" Version="4.32.9" />
		<PackageReference Include="SkiaSharp.Views.Maui.Controls" Version="3.119.0" />
		<PackageReference Condition="$(TargetFramework.Contains('windows'))" Include="System.Drawing.Common" Version="8.0.18" />
		<PackageReference Include="System.IdentityModel.Tokens.Jwt" Version="8.13.0" />
		<FrameworkReference Condition="$([MSBuild]::GetTargetPlatformIdentifier('$(TargetFramework)')) == 'windows'" Include="Microsoft.WindowsDesktop.App.WindowsForms" />

